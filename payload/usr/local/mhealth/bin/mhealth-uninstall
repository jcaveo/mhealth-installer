#!/bin/bash
# mhealth-uninstall — remove this user's mhealth setup.
# Does NOT remove the system payload at /usr/local/mhealth (other accounts may use it).
# To fully remove the payload, run:
#     sudo rm -rf /usr/local/mhealth /usr/local/bin/{mhealth,mhealth-kill,mhealth-activity,mac-health-watcher,mhealth-setup,mhealth-uninstall}

set -u

if [ "$(id -u)" = "0" ]; then
  echo "ERROR: run mhealth-uninstall as your user, not root." >&2
  echo "       It only touches files in your home directory." >&2
  exit 1
fi

LAUNCH_DIR="$HOME/Library/LaunchAgents"
UID_NUM="$(id -u)"

echo "Stopping and removing mhealth LaunchAgents…"
for job in watcher activity server; do
  plist="$LAUNCH_DIR/com.mhealth.${job}.plist"
  if [ -f "$plist" ]; then
    launchctl bootout "gui/${UID_NUM}" "$plist" 2>/dev/null || \
      launchctl unload "$plist" 2>/dev/null || true
    rm -f "$plist"
    echo "  ✓ removed $plist"
  fi
done

# Best-effort: stop any running server process
pkill -f "/usr/local/(bin|mhealth/bin)/mhealth-kill" 2>/dev/null || true

cat <<EOF

✓ mhealth user setup removed.

The following user data was kept (delete by hand if you want to):
  ~/Library/Logs/mac-health-watcher.log
  ~/Library/Logs/mhealth-activity.csv
  ~/Library/Logs/mac-health-snapshot.txt
  ~/Library/Application Support/mac-health-watcher/

To remove the system files (affects every user on this Mac):
  sudo rm -rf /usr/local/mhealth
  sudo rm -f /usr/local/bin/{mhealth,mhealth-kill,mhealth-activity,mac-health-watcher,mhealth-setup,mhealth-uninstall}
EOF
