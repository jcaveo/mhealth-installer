// Generic OAuth-based recipe (works for Box/Dropbox/OneDrive/pCloud — they all
// share the "auto config opens browser → click allow → done" pattern)
function oauthRecipe(displayName, rcloneType, storageNumber, signupUrl) {
  return `<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:14px;margin-top:10px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
      <h4 style="margin:0;color:#111827;font-size:14px">${displayName} setup</h4>
      <button onclick="document.getElementById('providerRecipe').style.display='none'" style="background:transparent;border:none;color:#6b7280;cursor:pointer;font-size:18px;padding:0 4px">×</button>
    </div>
    ${step(1, "Have an account ready", `Sign up free at <a href="${signupUrl}" target="_blank" rel="noopener" style="color:#f97316">${signupUrl.replace(/^https?:\/\//,'')}</a> if you don't have one.`)}
    ${step(2, "Open Terminal and run", codeBlockWithCopy("rclone config"))}
    ${step(3, "Answer the prompts", codeBlockWithCopy(`n/s/q>  n
name>   ${rcloneType}
Storage> ${storageNumber}
client_id>
client_secret>
${rcloneType === "onedrive" ? "region> 1\n" : ""}Edit advanced config? n
Use auto config? y
                          ← browser opens → sign in → grant access → "Success!"
${rcloneType === "onedrive" ? "Type of connection? 1\nDrive ID list>\nIs that okay? y\n" : ""}Keep this "${rcloneType}" remote? y
n/s/q> q`))}
    ${step(4, "Click Re-check below", `Your remote should appear above.`)}
    <div style="text-align:right;margin-top:8px"><button onclick="refreshCloud()" style="background:#f97316;color:#fff;border:none;border-radius:6px;padding:8px 14px;font-size:13px;cursor:pointer">Re-check</button></div>
  </div>`;
}

function fmtBytes(n) {
  if (n == null) return "—";
  if (n < 1024) return n + " B";
  if (n < 1048576) return (n/1024).toFixed(1) + " KB";
  if (n < 1073741824) return (n/1048576).toFixed(1) + " MB";
  return (n/1073741824).toFixed(2) + " GB";
}

async function refreshCloud() {
  const archEl = document.getElementById("archStatus");
  archEl.textContent = "Loading…"; archEl.className = "status";
  try {
    const r = await fetch("/cloud");
    cloudState = await r.json();
    if (cloudState.home) window.__HOME__ = cloudState.home;
    renderCloudHeader();
    renderArchives();
    archEl.textContent = "Updated " + new Date().toLocaleTimeString();
    archEl.className = "status ok";
  } catch (e) {
    archEl.textContent = "Failed: " + e.message;
    archEl.className = "status err";
  }
}

// All well-known free-tier providers we support recipes for.
// `match` is a function that, given an rclone remote {name, type}, returns true if that remote IS this provider.
const PROVIDER_CATALOG = [
  { id: "r2",       name: "Cloudflare R2",   free_gb: 10, tagline: "Zero egress fees",
    blurb: "Best technical fit — restores cost nothing at any size. S3-compatible.",
    match: r => r.type === "s3" || /r2/i.test(r.name) },
  { id: "mega",     name: "Mega",            free_gb: 20, tagline: "Biggest free tier",
    blurb: "20 GB free per account. Encryption-first (slightly slower up/down).",
    match: r => r.type === "mega" },
  { id: "gdrive",   name: "Google Drive",    free_gb: 15, tagline: "Easiest setup",
    blurb: "OAuth in browser — no tokens to copy. 3 min to configure.",
    match: r => r.type === "drive" },
  { id: "box",      name: "Box",             free_gb: 10, tagline: "Personal free tier",
    blurb: "10 GB free with file-size limit (250 MB per file).",
    match: r => r.type === "box" },
  { id: "dropbox",  name: "Dropbox",         free_gb: 2,  tagline: "Ubiquitous",
    blurb: "Small free tier (2 GB) but everyone has an account.",
    match: r => r.type === "dropbox" },
  { id: "onedrive", name: "OneDrive",        free_gb: 5,  tagline: "Microsoft",
    blurb: "5 GB free with personal Microsoft account.",
    match: r => r.type === "onedrive" },
  { id: "pcloud",   name: "pCloud",          free_gb: 10, tagline: "Swiss-based",
    blurb: "10 GB free, optional lifetime plans, decent speeds.",
    match: r => r.type === "pcloud" },
  { id: "storj",    name: "Storj",           free_gb: 25, tagline: "Decentralized",
    blurb: "25 GB free + 25 GB egress/mo. Distributed storage network.",
    match: r => r.type === "storj" },
];

// Render the providers grid: configured ones show usage; unconfigured show "Set up →"
function renderProvidersGrid() {
  const gridEl = document.getElementById("providersGrid");
  if (!gridEl) return;
  const remotes = cloudState.remotes || [];
  const html = PROVIDER_CATALOG.map(p => {
    const matched = remotes.find(r => p.match(r));
    const configured = !!matched;
    const cardBorder = configured ? "#86efac" : "#e5e7eb";
    const headerBg = configured ? "#d1fae5" : "#f9fafb";
    const statusBadge = configured
      ? '<span style="background:#16a34a;color:#fff;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600">✓ CONFIGURED</span>'
      : '<span style="background:#fed7aa;color:#7c2d12;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600">TO DO</span>';
    let bodyHtml;
    if (configured) {
      const has = matched.total != null;
      const pct = has && matched.total > 0 ? ((matched.used || 0) / matched.total * 100).toFixed(1) : null;
      const bar = has
        ? `<div style="height:6px;background:#e5e7eb;border-radius:3px;margin:6px 0;overflow:hidden"><div style="height:100%;width:${pct||0}%;background:#16a34a"></div></div>`
        : "";
      const usage = has
        ? `<div style="font-size:11px;color:#15803d">${fmtBytes(matched.used)} used · ${fmtBytes(matched.free)} free of ${fmtBytes(matched.total)}</div>`
        : '<div style="font-size:11px;color:#6b7280">Usage info unavailable for this backend</div>';
      bodyHtml = `
        <div style="font-size:11px;color:#6b7280">Remote name: <code>${escapeHtml(matched.name)}</code></div>
        ${bar}${usage}`;
    } else {
      bodyHtml = `
        <div style="font-size:11px;color:#6b7280;margin:4px 0 8px;min-height:30px">${escapeHtml(p.blurb)}</div>
        <button onclick="showRecipe('${p.id}')" style="width:100%;padding:6px;border:1px solid var(--accent);background:#fff;color:var(--accent);border-radius:6px;cursor:pointer;font-weight:500">Set up →</button>`;
    }
    return `<div style="border:2px solid ${cardBorder};border-radius:10px;overflow:hidden">
      <div style="padding:8px 12px;background:${headerBg};display:flex;justify-content:space-between;align-items:center">
        <div>
          <div style="font-weight:600;font-size:13px">${escapeHtml(p.name)}</div>
          <div style="font-size:10px;color:#6b7280">${p.free_gb} GB free · ${escapeHtml(p.tagline)}</div>
        </div>
        ${statusBadge}
      </div>
      <div style="padding:10px 12px">${bodyHtml}</div>
    </div>`;
  }).join("");
  gridEl.innerHTML = html;
  gridEl.style.display = "grid";

  // Overview stats
  const configuredCount = PROVIDER_CATALOG.filter(p => remotes.find(r => p.match(r))).length;
  const totalFree = remotes.reduce((s, r) => s + (r.free != null ? r.free : 0), 0);
  const totalUsed = remotes.reduce((s, r) => s + (r.used != null ? r.used : 0), 0);
  document.getElementById("cloudOverview").style.display = "flex";
  document.getElementById("cloudOverviewCounts").textContent = `${configuredCount} of ${PROVIDER_CATALOG.length}`;
  document.getElementById("cloudOverviewCapacity").textContent = totalFree > 0 ? fmtBytes(totalFree) + " across configured remotes" : "—";
  document.getElementById("cloudOverviewUsed").textContent = totalUsed > 0 ? fmtBytes(totalUsed) : "0 B";
}

function renderCloudHeader() {
  const setupEl = document.getElementById("cloudSetup");
  const setupBody = document.getElementById("cloudSetupBody");
  const remotesEl = document.getElementById("cloudRemotes");  // may be null in new layout
  const remoteSelect = document.getElementById("archiveRemote");
  // Compact versions on the Space tab
  const hintEl = document.getElementById("cloudSetupHint");
  const hintTextEl = document.getElementById("cloudSetupHintText");
  const compactRemotesEl = document.getElementById("cloudRemotesCompact");
  const readyEl = document.getElementById("cloudSetupReady");
  const showHint = (text) => {
    if (hintEl && hintTextEl) { hintTextEl.textContent = text; hintEl.style.display = "flex"; }
    if (compactRemotesEl) compactRemotesEl.style.display = "none";
  };
  const hideHint = () => { if (hintEl) hintEl.style.display = "none"; };
  const showReady = () => { if (readyEl) readyEl.style.display = "block"; };
  const hideReady = () => { if (readyEl) readyEl.style.display = "none"; };

  if (!cloudState.rclone_available) {
    setupEl.style.display = "block";
    setupBody.innerHTML = `
      <h3 style="margin:0 0 12px;font-size:15px;color:#7c2d12">Step 1 — Install rclone</h3>
      <div style="margin-bottom:8px">Open Terminal and run:</div>
      ${codeBlockWithCopy("brew install rclone")}
      <div style="font-size:12px;margin-top:10px;color:#92400e">
        Don't have Homebrew? Install it first from <a href="https://brew.sh" target="_blank" rel="noopener" style="color:#92400e;font-weight:600">brew.sh</a>.
      </div>
      <div style="margin-top:14px;font-size:12px;color:#7c2d12">
        rclone bridges to 30+ cloud providers. Free, open-source, no account needed for the tool itself. Once installed, all providers below become configurable.
      </div>`;
    if (document.getElementById("providersGrid")) document.getElementById("providersGrid").style.display = "none";
    if (document.getElementById("cloudOverview")) document.getElementById("cloudOverview").style.display = "none";
    if (remoteSelect) remoteSelect.innerHTML = "";
    hideReady();
    showHint("☁️ rclone isn't installed. Cloud Archive needs it — go to Cloud Setup tab to install.");
    return;
  }

  // rclone is installed — hide install step, show always-visible providers grid
  setupEl.style.display = "none";
  renderProvidersGrid();

  const configuredRemotes = cloudState.remotes || [];
  if (configuredRemotes.length === 0) {
    if (remoteSelect) remoteSelect.innerHTML = "";
    hideReady();
    showHint("☁️ No cloud remote configured yet. Pick a provider in Cloud Setup tab.");
    return;
  }

  // Have rclone + at least one remote — show ready hint + populate archive select
  showReady();

  // Compact remotes line for Archive tab
  if (compactRemotesEl) {
    const summary = configuredRemotes.map(r => {
      const has = r.total != null;
      const u = has ? ` (${fmtBytes(r.used)}/${fmtBytes(r.total)})` : "";
      return `<b>${escapeHtml(r.name)}</b>${u}`;
    }).join(" · ");
    compactRemotesEl.innerHTML = `☁️ Cloud ready: ${summary}`;
    compactRemotesEl.style.display = "block";
  }
  hideHint();

  // Populate archive-target select (used by the Archive tab scanner)
  if (remoteSelect) {
    const current = remoteSelect.value;
    remoteSelect.innerHTML = configuredRemotes
      .map(r => `<option value="${escapeHtml(r.name)}">${escapeHtml(r.name)}</option>`).join("");
    if (current && configuredRemotes.find(r => r.name === current)) remoteSelect.value = current;
  }
}

function renderArchives() {
  const rows = document.getElementById("archRows");
  const archives = cloudState.archives || [];
  rows.innerHTML = archives.length === 0
    ? `<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:20px">No archives yet.</td></tr>`
    : archives.map(a => {
        const dt = new Date(a.archived_at).toLocaleString([], {month:"short",day:"numeric",hour:"numeric",minute:"2-digit"});
        return `<tr>
          <td><code style="font-size:11px;word-break:break-all">${escapeHtml(a.original_path)}</code><div style="color:var(--muted);font-size:11px;margin-top:2px">archived ${escapeHtml(dt)}</div></td>
          <td><span class="badge">${escapeHtml(a.remote)}</span></td>
          <td class="num">${fmtBytes(a.size_bytes)}</td>
          <td>
            <button class="tiny" onclick="restoreArchive('${escapeHtml(a.id)}')">Restore</button>
            <button class="tiny danger" onclick="deleteArchiveItem('${escapeHtml(a.id)}','${escapeHtml(a.original_path)}')">Delete from cloud</button>
          </td>
        </tr>`;
      }).join("");
}

function setScanPreset(path) {
  document.getElementById("scanPath").value = path;
  scanFolder();
}

async function pickFolder() {
  const el = document.getElementById("scanStatus");
  el.textContent = "Opening folder picker…"; el.className = "status";
  try {
    const r = await fetch("/cloud/pick-folder");
    const j = await r.json();
    if (j.ok && j.path) {
      // Append to existing input (so user can build multi-path lists by browsing repeatedly)
      const existing = document.getElementById("scanPath").value.trim();
      const home = window.__HOME__ || "";
      const displayed = home && j.path.startsWith(home + "/") ? "~" + j.path.slice(home.length) : j.path;
      document.getElementById("scanPath").value = existing ? existing + ", " + displayed : displayed;
      el.textContent = "Picked: " + displayed;
      el.className = "status ok";
      scanFolder();
    } else if (j.cancelled) {
      el.textContent = "Cancelled"; el.className = "status";
    } else {
      el.textContent = "Picker failed: " + (j.error || "unknown"); el.className = "status err";
    }
  } catch (e) {
    el.textContent = "Failed: " + e.message; el.className = "status err";
  }
}

async function scanHomeOverview() {
  const el = document.getElementById("scanStatus");
  el.textContent = "Scanning home overview…"; el.className = "status";
  try {
    const r = await fetch("/cloud/home-overview");
    const j = await r.json();
    if (!j.ok) { el.textContent = "Error: " + j.error; el.className = "status err"; return; }
    // Synthesize a scan-result shape so existing rendering works
    const items = j.items.map(it => ({
      name: it.name, path: it.path, is_dir: it.is_dir, size_bytes: it.size_bytes,
      category: it.is_dir && it.size_bytes > 100 * 1024 * 1024 ? "archive" : "keep",
      reason: it.is_dir
        ? `Top-level home folder (${it.is_dir ? "directory" : "file"}). Click into a specific folder for full classification.`
        : "File in home root",
    }));
    scanResult = {
      ok: true,
      target: j.home + " (overview)",
      items,
      totals_bytes: items.reduce((acc, it) => {
        acc[it.category] = (acc[it.category] || 0) + it.size_bytes; return acc;
      }, {delete: 0, archive: 0, keep: 0, check: 0}),
    };
    renderScanResult();
    el.textContent = `Home overview: ${j.items.length} folder(s). Click into each for detail.`;
    el.className = "status ok";
  } catch (e) {
    el.textContent = "Failed: " + e.message; el.className = "status err";
  }
}

async function scanFolder(opts) {
  // opts.isDrillDown=true means "don't reset the navigation stack" (the caller
  // already pushed/popped). Default = fresh scan from the input box.
  const path = document.getElementById("scanPath").value.trim();
  if (!path) { alert("Enter a path to scan, click 📂 Browse, or pick a preset."); return; }
  const el = document.getElementById("scanStatus");
  el.textContent = "Scanning…"; el.className = "status";
  hideTccHelp();
  try {
    const r = await fetch("/cloud/scan?path=" + encodeURIComponent(path));
    const j = await r.json();
    if (!j.ok && !j.items) {
      el.textContent = "Error";
      el.className = "status err";
      if (/permission denied|not permitted|TCC|privacy/i.test(j.error || "")) {
        showTccHelp(path, j.error);
      } else {
        alert("Scan failed: " + j.error);
      }
      return;
    }

    // Manage navigation stack for fresh scans (not drill-downs).
    // Multi-path scans disable drill-down entirely.
    if (!opts || !opts.isDrillDown) {
      const isMultiPath = path.includes(",");
      if (isMultiPath) {
        navigationStack = []; // breadcrumbs hidden for multi-path
      } else {
        const label = pathDisplayName(path);
        navigationStack = [{ path: path, resolved: j.target, label }];
      }
    }

    scanResult = j;
    renderScanResult();
    const errPart = (j.errors && j.errors.length) ? ` (${j.errors.length} path failed)` : "";
    el.textContent = `Scanned ${j.items.length} item(s)${errPart}`;
    el.className = j.errors && j.errors.length ? "status err" : "status ok";
  } catch (e) {
    el.textContent = "Failed: " + e.message;
    el.className = "status err";
  }
}

function pathDisplayName(p) {
  const home = window.__HOME__ || "";
  if (home && p === home) return "~";
  if (home && p.startsWith(home + "/")) return "~/" + p.slice(home.length + 1).split("/").pop();
  return p.split("/").filter(Boolean).pop() || p;
}

function pathDisplayFull(p) {
  const home = window.__HOME__ || "";
  if (home && p.startsWith(home + "/")) return "~/" + p.slice(home.length + 1);
  if (home && p === home) return "~";
  return p;
}

// Click a folder row → push it onto the stack and scan into it.
async function drillIntoFolder(path) {
  const label = pathDisplayName(path);
  navigationStack.push({ path, resolved: path, label });
  document.getElementById("scanPath").value = pathDisplayFull(path);
  await scanFolder({ isDrillDown: true });
}

// Click a breadcrumb segment → truncate stack to that index and scan.
async function navigateToBreadcrumb(index) {
  if (index < 0 || index >= navigationStack.length) return;
  navigationStack = navigationStack.slice(0, index + 1);
  const target = navigationStack[index];
  document.getElementById("scanPath").value = pathDisplayFull(target.resolved || target.path);
  await scanFolder({ isDrillDown: true });
}

// "Up" button — pop one off the stack.
async function navigateUp() {
  if (navigationStack.length <= 1) return;
  navigationStack.pop();
  const target = navigationStack[navigationStack.length - 1];
  document.getElementById("scanPath").value = pathDisplayFull(target.resolved || target.path);
  await scanFolder({ isDrillDown: true });
}

function renderBreadcrumbs() {
  const el = document.getElementById("scanBreadcrumbs");
  if (!el) return;
  if (navigationStack.length <= 0) { el.style.display = "none"; return; }
  const segments = navigationStack.map((seg, i) => {
    const isLast = i === navigationStack.length - 1;
    const safe = escapeHtml(seg.label);
    if (isLast) {
      return `<span style="color:#111827;font-weight:600">${safe}</span>`;
    }
    return `<a onclick="navigateToBreadcrumb(${i})" style="color:#2563eb;cursor:pointer;text-decoration:underline">${safe}</a>`;
  }).join('<span style="color:var(--muted)">/</span>');
  const upBtn = navigationStack.length > 1
    ? `<button onclick="navigateUp()" class="tiny" style="margin-right:8px" title="Go up one level">↑</button>`
    : "";
  el.innerHTML = `<span style="color:var(--muted)">📍</span> ${upBtn}${segments}
    <span style="margin-left:auto;color:var(--muted);font-size:11px">${escapeHtml(pathDisplayFull((navigationStack[navigationStack.length-1].resolved || navigationStack[navigationStack.length-1].path)))}</span>`;
  el.style.display = "flex";
}

function hideTccHelp() {
  const el = document.getElementById("tccHelp");
  if (el) el.style.display = "none";
}

async function showTccHelp(path, rawError) {
  let el = document.getElementById("tccHelp");
  if (!el) {
    el = document.createElement("div");
    el.id = "tccHelp";
    el.style.cssText = "background:#fff7ed;border:2px solid #fb923c;border-radius:10px;padding:16px 20px;margin:14px 0;color:#7c2d12";
    // Insert above the scan table area, after the Browse toolbar
    const anchor = document.getElementById("scanTable");
    anchor.parentNode.insertBefore(el, anchor);
  }
  // Get the actual python paths from the server. Critically, tcc_target prefers an
  // enclosing .app bundle if the running process is inside one — macOS TCC validates
  // against the .app, not the bin/python3 symlink.
  let info = {
    sys_executable: "/usr/bin/python3",
    sys_executable_real: "/usr/bin/python3",
    running_binary: null,
    tcc_target: "/usr/bin/python3",
    running_app_bundle: null,
  };
  try {
    const r = await fetch("/system/open-privacy-settings");
    info = { ...info, ...(await r.json()) };
  } catch {}
  const isAppBundle = !!info.running_app_bundle;
  const grantTarget = info.tcc_target;
  const grantTargetName = grantTarget.split("/").pop();
  const grantWhat = isAppBundle ? "the Python.app bundle" : "python3";
  el.innerHTML = `
    <h3 style="margin:0 0 10px;font-size:15px;color:#7c2d12">🔒 macOS is blocking access to <code>${escapeHtml(path)}</code></h3>
    <p style="margin:0 0 8px;font-size:13px">macOS protects <b>Documents</b>, <b>Desktop</b>, and <b>Downloads</b> behind Full Disk Access. The running mhealth process is:</p>
    <div style="background:#fff;border:1px solid #fed7aa;border-radius:6px;padding:8px 12px;margin-bottom:14px;font-size:11px;font-family:ui-monospace,Menlo,monospace;word-break:break-all">
      ${escapeHtml(info.running_binary || info.sys_executable_real)}
      ${isAppBundle ? `<div style="margin-top:6px;color:#16a34a;font-family:inherit;font-size:12px"><b>⚠️ This binary lives inside a <code>.app</code> bundle.</b> macOS TCC validates against the <code>.app</code>, not the inner binary. <b>You must drag the .app, not python3.</b></div>` : ""}
    </div>

    <div style="background:#fff;border:1px solid #fb923c;border-radius:8px;padding:12px;margin-bottom:14px">
      <div style="font-weight:600;margin-bottom:8px;color:#7c2d12">⭐ Steps:</div>
      <ol style="margin:0 0 6px 22px;padding:0;font-size:13px;line-height:1.7">
        <li>
          <button onclick="revealPython()" style="padding:4px 12px;border-radius:4px;border:1px solid #fb923c;background:#fff;cursor:pointer;font-weight:500">📂 Show ${escapeHtml(grantTargetName)} in Finder</button>
          — opens Finder with ${escapeHtml(grantWhat)} highlighted
        </li>
        <li>
          <button onclick="openPrivacySettings()" style="padding:4px 12px;border-radius:4px;border:1px solid #fb923c;background:#fff;cursor:pointer;font-weight:500">⚙️ Open Privacy Settings</button>
          — opens System Settings → Privacy &amp; Security
        </li>
        <li>Scroll to <b>Full Disk Access</b> in Settings</li>
        <li><b>${isAppBundle ? "If <code>python3</code> is already in the list, remove it first (click − while it's selected)." : "If a stale <code>python3</code> entry exists, remove it first."}</b></li>
        <li><b>Drag</b> the highlighted <code>${escapeHtml(grantTargetName)}</code> from Finder <b>into</b> the Full Disk Access list</li>
        <li>Make sure the toggle next to it is <b>ON</b></li>
        <li><button onclick="restartServerAndRescan('${escapeHtml(path)}')" style="padding:4px 12px;border-radius:4px;border:1px solid #fb923c;background:#fb923c;color:#fff;cursor:pointer;font-weight:500">Restart server &amp; rescan</button></li>
        <li style="color:#7c2d12;font-size:12px">Still not working? <button onclick="runTccDiagnose()" style="padding:2px 8px;border-radius:4px;border:1px solid #fb923c;background:#fff;cursor:pointer">🔍 Diagnose</button></li>
      </ol>
    </div>

    <div id="tccDiagnoseOutput" style="display:none;background:#1f2937;color:#e5e7eb;border-radius:8px;padding:12px 16px;margin-bottom:14px;font-family:ui-monospace,Menlo,monospace;font-size:11px;white-space:pre-wrap;overflow:auto;max-height:300px"></div>

    <details style="font-size:12px;color:#92400e;margin-top:6px">
      <summary style="cursor:pointer">Manual path (advanced)</summary>
      <div style="margin-top:8px">
        In Privacy &amp; Security → Full Disk Access → click <b>+</b> → Cmd+Shift+G → paste path → Enter.
      </div>
      <div style="margin-top:6px">
        <div style="font-size:11px;color:#7c2d12;margin-bottom:2px"><b>Best target</b> (what macOS validates against):</div>
        <div style="display:flex;gap:6px;align-items:center">
          <code style="flex:1;padding:6px 10px;background:#fff;border:1px solid #fed7aa;border-radius:4px;font-size:12px;user-select:all">${escapeHtml(grantTarget)}</code>
          <button onclick="copyTextToClipboard('${escapeHtml(grantTarget)}', this)" style="padding:4px 10px;border-radius:4px;border:1px solid #fb923c;background:#fff;cursor:pointer">Copy</button>
        </div>
      </div>
      <div style="margin-top:6px;font-size:11px;color:#92400e">Other paths involved:</div>
      <div style="margin-top:2px;font-size:11px;font-family:ui-monospace,Menlo,monospace;color:#92400e">
        sys.executable:&nbsp;${escapeHtml(info.sys_executable)}<br>
        realpath:&nbsp;${escapeHtml(info.sys_executable_real)}<br>
        ${info.running_binary ? `running:&nbsp;${escapeHtml(info.running_binary)}<br>` : ""}
        ${info.running_app_bundle ? `app:&nbsp;${escapeHtml(info.running_app_bundle)}` : ""}
      </div>
    </details>

    <details style="font-size:12px;color:#92400e;margin-top:8px">
      <summary style="cursor:pointer">Why? + raw error</summary>
      <p style="margin:6px 0">macOS's TCC (Transparency, Consent &amp; Control) blocks background services from reading Documents/Desktop/Downloads without explicit user consent. TCC validates against the <i>actually-running</i> binary or its enclosing <code>.app</code> bundle — not necessarily what <code>which python3</code> or symlinks point at.</p>
      <p style="margin:6px 0"><b>Raw error:</b> ${escapeHtml(rawError || "")}</p>
    </details>
  `;
  el.style.display = "block";
}

async function runTccDiagnose() {
  const out = document.getElementById("tccDiagnoseOutput");
  if (!out) return;
  out.style.display = "block";
  out.textContent = "Running diagnostic…";
  try {
    const r = await fetch("/system/tcc-diagnose");
    const j = await r.json();
    const reads = j.reads || {};
    const lines = [];
    lines.push("=== Permission test (what the server can ACTUALLY read right now) ===");
    for (const [name, res] of Object.entries(reads)) {
      const icon = res.ok === true ? "✓" : res.ok === null ? "—" : "✗";
      lines.push(`  ${icon} ~/${name.padEnd(10)} ${res.ok ? "OK" : "BLOCKED: " + (res.error || "")}`);
    }
    lines.push("");
    lines.push("=== Running process ===");
    lines.push(`  sys.executable:        ${j.sys_executable}`);
    lines.push(`  realpath:              ${j.sys_executable_real}`);
    if (j.running_binary) lines.push(`  ps reports running:    ${j.running_binary}`);
    if (j.running_app_bundle) lines.push(`  enclosing .app bundle: ${j.running_app_bundle}`);
    lines.push(`  TCC target (best):     ${j.tcc_target}`);
    lines.push("");
    const allOk = Object.values(reads).every(r => r.ok !== false);
    if (allOk) {
      lines.push("✅ All protected directories are readable. Try Scan again.");
    } else {
      lines.push("❌ Still blocked. Common fixes:");
      lines.push("   1. In Privacy → Full Disk Access, REMOVE any stale python3 entries");
      lines.push("      (click the − button after selecting them).");
      lines.push("   2. Drag the file shown as 'TCC target (best)' from Finder into the list.");
      lines.push("   3. Toggle it ON.");
      lines.push("   4. Click Restart server & rescan.");
      lines.push("   5. If STILL blocked: log out and back in, or reboot. macOS TCC");
      lines.push("      sometimes caches old grants and needs a full session restart.");
    }
    out.textContent = lines.join("\n");
  } catch (e) {
    out.textContent = "Diagnose failed: " + e.message;
  }
}

async function revealPython() {
  try {
    const r = await fetch("/system/reveal-python");
    const j = await r.json();
    if (!j.ok) alert("Couldn't reveal python: " + (j.path || ""));
  } catch (e) {
    alert("Reveal failed: " + e.message);
  }
}

async function openPrivacySettings() {
  await fetch("/system/open-privacy-settings");
}

async function copyTextToClipboard(text, btn) {
  try {
    await navigator.clipboard.writeText(text);
    const orig = btn.textContent;
    btn.textContent = "✓ Copied";
    setTimeout(() => { btn.textContent = orig; }, 1500);
  } catch (e) {
    btn.textContent = "Copy failed";
  }
}

async function restartServerAndRescan(path) {
  // Show a blocking overlay while we wait for launchd to bring the server back.
  let overlay = document.getElementById("restartOverlay");
  if (!overlay) {
    overlay = document.createElement("div");
    overlay.id = "restartOverlay";
    overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:10000;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px";
    document.body.appendChild(overlay);
  }
  overlay.innerHTML = `<div style="background:#1f2937;border-radius:10px;padding:24px 32px;text-align:center;min-width:280px">
    <div style="font-size:28px;margin-bottom:10px">⏳</div>
    <div id="restartMsg" style="font-weight:600;margin-bottom:6px">Restarting server…</div>
    <div style="font-size:12px;opacity:0.7" id="restartSub">Triggering shutdown. launchd will bring it back in a moment.</div>
  </div>`;
  overlay.style.display = "flex";

  // 1. Tell the server to restart.
  try {
    await fetch("/system/restart", { method: "POST" });
  } catch {
    // The fetch may fail because the server exits before sending — that's expected.
  }

  // 2. Poll /ping until it answers again.
  const msg = document.getElementById("restartMsg");
  const sub = document.getElementById("restartSub");
  const deadline = Date.now() + 20000; // 20 s max wait
  await new Promise(r => setTimeout(r, 800)); // give launchd a head start
  while (Date.now() < deadline) {
    try {
      const r = await fetch("/ping", { cache: "no-store" });
      if (r.ok) {
        msg.textContent = "Server restored. Rescanning…";
        sub.textContent = "";
        break;
      }
    } catch {
      // Still down — keep polling
    }
    sub.textContent = `Waiting for server… (${Math.ceil((deadline - Date.now()) / 1000)} s left)`;
    await new Promise(r => setTimeout(r, 500));
  }

  // 3. Hide overlay and re-scan.
  setTimeout(() => { overlay.style.display = "none"; }, 800);
  document.getElementById("scanPath").value = path;
  setTimeout(() => scanFolder(), 1000);
}

function renderScanResult() {
  if (!scanResult) return;
  document.getElementById("scanLegend").style.display = "block";
  document.getElementById("scanActions").style.display = "block";
  document.getElementById("scanTable").style.display = "table";
  renderBreadcrumbs();

  const t = scanResult.totals_bytes || {};
  document.getElementById("scanTotals").style.display = "block";
  document.getElementById("scanTotals").innerHTML = `
    <b>Totals:</b>
    🗑 ${fmtBytes(t.delete || 0)} regenerable ·
    ☁️ ${fmtBytes(t.archive || 0)} cold ·
    ⚠️ ${fmtBytes(t.check || 0)} git repos ·
    🔒 ${fmtBytes(t.keep || 0)} keep`;

  const icon = (c) => ({delete:"🗑", archive:"☁️", check:"⚠️", keep:"🔒"}[c] || "");
  const sorted = [...scanResult.items].sort((a, b) => b.size_bytes - a.size_bytes);
  document.getElementById("scanRows").innerHTML = sorted.map(it => {
    // Folder names are clickable → drill into them. Files are plain.
    const nameCell = it.is_dir
      ? `<a onclick="drillIntoFolder('${escapeHtml(it.path)}')" style="color:#2563eb;cursor:pointer;font-weight:600" title="Click to drill into this folder">${escapeHtml(it.name)}</a><span style="color:var(--muted);font-size:11px"> /</span>`
      : `<b>${escapeHtml(it.name)}</b>`;
    const revealBtn = `<button class="tiny" onclick="revealPathInFinder('${escapeHtml(it.path)}')" title="Reveal in Finder" style="padding:2px 6px;font-size:10px;margin-left:6px">↗</button>`;
    return `<tr data-category="${escapeHtml(it.category)}">
      <td><input type="checkbox" class="scan-cb" data-path="${escapeHtml(it.path)}" data-category="${escapeHtml(it.category)}"></td>
      <td style="font-size:16px;text-align:center">${icon(it.category)}</td>
      <td>${nameCell}${revealBtn}</td>
      <td class="num">${fmtBytes(it.size_bytes)}</td>
      <td><span class="badge">${escapeHtml(it.category)}</span></td>
      <td><span class="desc">${escapeHtml(it.reason)}</span></td>
    </tr>`;
  }).join("");
}

async function revealPathInFinder(path) {
  await fetch("/reveal?path=" + encodeURIComponent(path)).catch(() => {});
}

function toggleAllScan() {
  const on = document.getElementById("scanSelAll").checked;
  document.querySelectorAll(".scan-cb").forEach(cb => cb.checked = on);
}

function selectedScan(category) {
  return Array.from(document.querySelectorAll(".scan-cb"))
    .filter(cb => cb.checked && (!category || cb.dataset.category === category))
    .map(cb => cb.dataset.path);
}

async function deleteRegenerableSelected() {
  const paths = selectedScan("delete");
  if (paths.length === 0) {
    alert("No items in 'delete' category are selected.\\nTip: click the header checkbox to select all, then this button will only act on 🗑 items.");
    return;
  }
  if (!confirm(`Delete ${paths.length} regenerable item(s)? They will be re-created by npm install / docker pull / build tools when needed.`)) return;
  const r = await fetch("/cloud/delete-bulk", {
    method: "POST", headers: {"Content-Type": "application/json"},
    body: JSON.stringify({paths}),
  });
  const j = await r.json();
  alert(`Deleted ${j.deleted}, failed ${j.failed.length}, skipped ${j.skipped.length}.`);
  scanFolder();
}

async function archiveSelected() {
  const remote = document.getElementById("archiveRemote").value;
  if (!remote) { alert("Select a remote first."); return; }
  // Allow archive or check categories (user accepts risk on check via confirm)
  const archivable = Array.from(document.querySelectorAll(".scan-cb"))
    .filter(cb => cb.checked && (cb.dataset.category === "archive" || cb.dataset.category === "check"))
    .map(cb => cb.dataset.path);
  if (archivable.length === 0) {
    alert("No archivable items selected (need ☁️ or ⚠️ category).");
    return;
  }
  const hasCheck = Array.from(document.querySelectorAll(".scan-cb"))
    .some(cb => cb.checked && cb.dataset.category === "check");
  let msg = `Archive ${archivable.length} item(s) to ${remote}? Each will be uploaded, verified, then deleted locally.`;
  if (hasCheck) msg += "\\n\\n⚠️ Includes git repos — confirm no untracked/unpushed work first.";
  if (!confirm(msg)) return;

  const status = document.getElementById("scanStatus");
  let okCount = 0, failed = [];
  for (let i = 0; i < archivable.length; i++) {
    const p = archivable[i];
    status.textContent = `Archiving ${i+1}/${archivable.length}: ${p.split("/").pop()}…`;
    status.className = "status";
    try {
      const r = await fetch("/cloud/archive", {
        method: "POST", headers: {"Content-Type": "application/json"},
        body: JSON.stringify({path: p, remote}),
      });
      const j = await r.json();
      if (j.ok) okCount++; else failed.push({path: p, err: j.error});
    } catch (e) {
      failed.push({path: p, err: e.message});
    }
  }
  status.textContent = `Archived ${okCount} of ${archivable.length}`;
  status.className = okCount === archivable.length ? "status ok" : "status err";
  if (failed.length) {
    alert("Some failed:\\n" + failed.map(f => `${f.path}\\n  → ${f.err}`).join("\\n\\n"));
  }
  refreshCloud();
  scanFolder();
}

async function restoreArchive(id) {
  if (!confirm("Restore this archive to its original path?")) return;
  const r = await fetch("/cloud/restore", {
    method: "POST", headers: {"Content-Type": "application/json"},
    body: JSON.stringify({id, keep_remote: true}),
  });
  const j = await r.json();
  if (j.ok) {
    alert("Restored to " + j.entry.original_path + "\\n\\nCloud copy kept as backup. Use 'Delete from cloud' to remove it.");
  } else {
    alert("Restore failed: " + (j.error || "unknown"));
  }
  refreshCloud();
}

async function deleteArchiveItem(id, name) {
  if (!confirm(`Delete cloud copy of "${name}"?\\nThis removes the remote files AND the archive record.\\nLocal files (if any) are untouched.`)) return;
  await fetch("/cloud?id=" + encodeURIComponent(id), { method: "DELETE" });
  refreshCloud();
}

// --- Projects tracker ----------------------------------------------------
let projectsCache = [];

async function refreshProjects() {
  const el = document.getElementById("projStatus");
  el.textContent = "Loading…"; el.className = "status";
  try {
    const r = await fetch("/projects");
    const j = await r.json();
    projectsCache = j.items || [];
    renderProjects();
    el.textContent = "Updated " + new Date().toLocaleTimeString();
    el.className = "status ok";
  } catch (e) {
    el.textContent = "Failed: " + e.message;
    el.className = "status err";
  }
}

function stateLabel(s) {
  if (s === "in_progress") return '<span class="badge" style="background:#fef3c7;color:#92400e">In progress</span>';
  if (s === "finished") return '<span class="badge" style="background:#d1fae5;color:#065f46">Finished</span>';
  if (s === "unfinished") return '<span class="badge" style="background:#fee2e2;color:#991b1b">Unfinished</span>';
  return `<span class="badge">${escapeHtml(s||"")}</span>`;
}

function renderProjects() {
  const filter = document.getElementById("projFilter").value;
  const items = projectsCache.filter(p => filter === "all" || p.state === filter);
  document.getElementById("projCount").textContent = `(${projectsCache.length}${filter !== "all" ? " · " + items.length + " shown" : ""})`;
  document.getElementById("projRows").innerHTML = items.length === 0
    ? `<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:24px">${projectsCache.length === 0 ? 'No projects yet. Click "+ Add project" to track your first one.' : "No projects match this filter."}</td></tr>`
    : items.map(p => {
        const pathDisplay = (p.path || "").replace(/^~\//, "~/");
        const revealable = p.path && p.path.startsWith("~/");
        return `<tr>
          <td><b>${escapeHtml(p.name || "")}</b></td>
          <td><span class="desc">${escapeHtml(p.description || "")}</span></td>
          <td>${stateLabel(p.state)}</td>
          <td style="color:var(--muted);font-size:12px">${escapeHtml(p.last_work_date || "")}</td>
          <td><code style="font-size:11px;color:var(--muted);word-break:break-all">${escapeHtml(pathDisplay)}</code></td>
          <td><span class="desc">${escapeHtml(p.pending || "")}</span></td>
          <td>
            ${revealable ? `<button class="tiny" onclick="revealProject('${escapeHtml(p.path)}')">Open</button>` : ""}
            <button class="tiny" onclick="editProject('${escapeHtml(p.id)}')">Edit</button>
            <button class="tiny" onclick="deleteProject('${escapeHtml(p.id)}', '${escapeHtml(p.name || "")}')">Delete</button>
          </td>
        </tr>`;
      }).join("");
}

async function revealProject(path) {
  await fetch("/reveal?path=" + encodeURIComponent(path));
}

function openProjectModal() {
  document.getElementById("projModalTitle").textContent = "Add project";
  document.getElementById("projId").value = "";
  document.getElementById("projName").value = "";
  document.getElementById("projDesc").value = "";
  document.getElementById("projState").value = "in_progress";
  document.getElementById("projDate").value = new Date().toISOString().slice(0, 10);
  document.getElementById("projPath").value = "";
  document.getElementById("projPending").value = "";
  document.getElementById("projModal").style.display = "flex";
  setTimeout(() => document.getElementById("projName").focus(), 50);
}

function closeProjectModal() {
  document.getElementById("projModal").style.display = "none";
}

function editProject(id) {
  const p = projectsCache.find(x => x.id === id);
  if (!p) return;
  document.getElementById("projModalTitle").textContent = "Edit project";
  document.getElementById("projId").value = p.id;
  document.getElementById("projName").value = p.name || "";
  document.getElementById("projDesc").value = p.description || "";
  document.getElementById("projState").value = p.state || "in_progress";
  document.getElementById("projDate").value = p.last_work_date || new Date().toISOString().slice(0, 10);
  document.getElementById("projPath").value = p.path || "";
  document.getElementById("projPending").value = p.pending || "";
  document.getElementById("projModal").style.display = "flex";
  setTimeout(() => document.getElementById("projName").focus(), 50);
}

async function saveProject(ev) {
  ev.preventDefault();
  const id = document.getElementById("projId").value.trim();
  const project = {
    name: document.getElementById("projName").value.trim(),
    description: document.getElementById("projDesc").value.trim(),
    state: document.getElementById("projState").value,
    last_work_date: document.getElementById("projDate").value,
    path: document.getElementById("projPath").value.trim(),
    pending: document.getElementById("projPending").value.trim(),
  };
  if (!project.name) {
    alert("Name is required.");
    return;
  }
  const body = id
    ? { op: "update", id, project }
    : { op: "add", project };
  try {
    const r = await fetch("/projects", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const j = await r.json();
    if (!j.ok) {
      alert("Save failed: " + (j.error || "unknown error"));
      return;
    }
    closeProjectModal();
    refreshProjects();
  } catch (e) {
    alert("Save failed: " + e.message);
  }
}

async function deleteProject(id, name) {
  if (!confirm(`Delete project "${name}"? This only removes the tracker entry, not any files.`)) return;
  try {
    await fetch("/projects?id=" + encodeURIComponent(id), { method: "DELETE" });
    refreshProjects();
  } catch (e) {
    alert("Delete failed: " + e.message);
  }
}

// Close modal on Escape
document.addEventListener("keydown", (e) => {
  if (e.key === "Escape" && document.getElementById("projModal")?.style.display === "flex") {
    closeProjectModal();
  }
});

// --- Time spent ---
function fmtMin(m) {
  if (m < 60) return `${m}m`;
  const h = Math.floor(m / 60), mm = m % 60;
  return mm ? `${h}h ${mm}m` : `${h}h`;
}
async function refreshActivity() {
  const range = document.getElementById("timeRange").value;
  const el = document.getElementById("timeStatus");
  el.textContent = "Loading…"; el.className = "status";
  try {
    const r = await fetch("/activity?range=" + encodeURIComponent(range));
    const j = await r.json();
    renderActivity(j);
    el.textContent = `Updated ${new Date().toLocaleTimeString()}`;
    el.className = "status ok";
  } catch (e) {
    el.textContent = "Failed: " + e.message; el.className = "status err";
  }
}
function renderActivity(j) {
  // Banner if no activity log yet
  const banner = document.getElementById("timeBanner");
  if (!j.activity_log_exists) {
    banner.style.display = "flex";
    banner.querySelector("span").innerHTML =
      "💡 Activity logger hasn't run yet. Once <code>com.jc.mhealth-activity</code> launchd job runs (every 60 s), app-time data will start populating. Browser & shell history are shown immediately.";
  } else if (j.rows_collected === 0) {
    banner.style.display = "flex";
    banner.querySelector("span").textContent =
      `Activity log exists but has no rows in this range yet. Pick a wider range or wait for more samples.`;
  } else {
    banner.style.display = "none";
  }

  document.getElementById("timeTotals").textContent =
    j.rows_collected
      ? `· active ${fmtMin(j.active_minutes)} · idle ${fmtMin(j.idle_minutes)} · total tracked ${fmtMin(j.total_minutes)}`
      : "· no activity log data for this range";

  const maxMin = Math.max(1, ...(j.apps || []).map(a => a.minutes));
  const appsHtml = (j.apps || []).map(a => {
    const w = Math.max(2, Math.round((a.minutes / maxMin) * 100));
    return `<div style="display:grid;grid-template-columns:24px 1fr 80px 50px;gap:8px;align-items:center;padding:4px 6px">
      <div style="height:8px;background:var(--accent);border-radius:4px;width:${w}%;justify-self:start;min-width:6px"></div>
      <div>${escapeHtml(a.app)}</div>
      <div style="text-align:right;font-variant-numeric:tabular-nums">${fmtMin(a.minutes)}</div>
      <div style="text-align:right;color:var(--muted)">${a.pct}%</div>
    </div>`;
  }).join("");
  document.getElementById("appTimeRows").innerHTML =
    appsHtml || `<div style="color:var(--muted);padding:12px;text-align:center">No app-time data yet for this range.</div>`;

  document.getElementById("siteRows").innerHTML =
    (j.top_sites || []).map(s => {
      const mins = s.minutes || 0;
      const timeCell = mins > 0
        ? `<span style="font-variant-numeric:tabular-nums">${fmtMin(mins)}</span>`
        : '<span style="color:var(--muted)">—</span>';
      return `<tr>
        <td>${escapeHtml(s.host)}</td>
        <td><span class="browser-tag ${s.browser}"><span class="browser-dot ${s.browser}"></span>${s.browser}</span></td>
        <td class="num">${timeCell}</td>
        <td class="num">${s.visits}</td>
      </tr>`;
    }).join("") || `<tr><td colspan="4" style="color:var(--muted);text-align:center">No browser history in range.</td></tr>`;

  document.getElementById("cmdRows").innerHTML =
    (j.top_commands || []).map(c => `<tr>
      <td><code>${escapeHtml(c.command)}</code></td>
      <td class="num">${c.count}</td>
    </tr>`).join("") || `<tr><td colspan="2" style="color:var(--muted);text-align:center">No shell commands in range.</td></tr>`;
}

// --- Disk cleanup ---
let diskItems = [];
function setDiskStatus(msg, cls) {
  const el = document.getElementById("diskStatus");
  el.textContent = msg; el.className = "status " + (cls || "");
}
async function refreshDisk(force) {
  setDiskStatus("Scanning…", "");
  try {
    const r = await fetch("/disk" + (force ? "?force=1" : ""));
    const j = await r.json();
    diskItems = j.items || [];
    renderDisk();
    setDiskStatus("Updated " + new Date().toLocaleTimeString(), "ok");
  } catch (e) {
    setDiskStatus("Scan failed: " + e.message, "err");
  }
}
let diskRiskFilter = "all";  // all | safe | caution | danger

function setRiskFilter(level) {
  diskRiskFilter = level;
  // Visual: highlight active filter button
  document.querySelectorAll(".riskFilter").forEach(b => {
    const active = b.dataset.risk === level;
    b.style.background = active ? "var(--accent)" : "";
    b.style.color = active ? "#fff" : "";
    b.style.borderColor = active ? "var(--accent)" : "";
  });
  renderDisk();
}

function renderDisk() {
  const meta = diskItems.find(x => x._meta)?._meta || {};
  const allItems = diskItems.filter(x => !x._meta);
  const items = diskRiskFilter === "all"
    ? allItems
    : allItems.filter(x => (x.risk || x.level || "safe") === diskRiskFilter);
  const usedPct = parseInt(meta.pct || "0");
  document.getElementById("diskSummary").innerHTML = `
    <div><div style="font-size:11px;color:var(--muted)">Total</div><div style="font-weight:600">${meta.total_gb || "?"} GB</div></div>
    <div><div style="font-size:11px;color:var(--muted)">Used</div><div style="font-weight:600">${meta.used_gb || "?"} GB (${meta.pct || "?"})</div></div>
    <div><div style="font-size:11px;color:var(--muted)">Free</div><div style="font-weight:600">${meta.avail_gb || "?"} GB</div></div>
    <div class="disk-bar"><div class="disk-bar-fill" style="width:${usedPct}%"></div></div>
    <div><div style="font-size:11px;color:var(--muted)">Total recoverable</div><div style="font-weight:600;color:var(--ok)">${allItems.reduce((s,i)=>s+i.size_mb,0)} MB</div></div>
  `;
  // Filter counts in header
  const counts = allItems.reduce((acc, it) => { const r = it.risk || it.level || "safe"; acc[r] = (acc[r]||0)+1; return acc; }, {safe:0,caution:0,danger:0});
  document.getElementById("diskCount").textContent = `${items.length} of ${allItems.length} shown  ·  🟢 ${counts.safe}  🟡 ${counts.caution}  🔴 ${counts.danger}`;

  if (items.length === 0) {
    document.getElementById("diskRows").innerHTML = `<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:24px">${allItems.length === 0 ? 'No cleanup candidates over 10 MB. Disk is reasonably tidy.' : 'No items match the current filter.'}</td></tr>`;
    return;
  }
  document.getElementById("diskRows").innerHTML = items.map((it, i) => {
    const risk = it.risk || it.level || "safe";
    const riskBadge = riskBadgeHtml(risk);
    const isDocker = it.action === "docker-prune";
    const isRisky = risk === "danger" || risk === "caution";
    const sizeDisplay = it.size_mb >= 1024 ? `${(it.size_mb/1024).toFixed(1)} GB` : `${it.size_mb} MB`;
    const tooltip = [it.desc, it.what_breaks && ("What breaks: " + it.what_breaks), it.regen && ("Regen: " + it.regen)].filter(Boolean).join("\n\n");
    const pathDisplay = (window.__HOME__ || window.localStorage.getItem('home') || '').length ? it.path.replace(window.__HOME__ || window.localStorage.getItem('home'), '~') : it.path;
    const action = isDocker
      ? `<button class="tiny" onclick="runDockerPrune()" style="background:#fed7aa;border-color:#f59e0b">Prune (safe)</button>`
      : `<button class="tiny" onclick="cleanOneByPath('${escapeHtml(it.path)}')">Clean</button>`;
    const cbDisabled = isDocker ? "disabled title='Use the Prune button, not bulk delete'" : "";
    return `<tr data-path="${escapeHtml(it.path)}" class="${isRisky ? 'risky' : ''}" title="${escapeHtml(tooltip)}">
      <td><input type="checkbox" class="disk-cb" data-path="${escapeHtml(it.path)}" onchange="onDiskSelChange(this)" ${cbDisabled}></td>
      <td>${riskBadge}</td>
      <td class="num"><b>${sizeDisplay}</b></td>
      <td><span class="badge">${escapeHtml(it.category)}</span></td>
      <td><code style="font-size:11px;color:var(--muted)">${escapeHtml(pathDisplay)}</code></td>
      <td>
        <div style="font-size:12px">${escapeHtml(it.desc)}</div>
        ${it.what_breaks ? `<div style="font-size:11px;color:var(--muted);margin-top:2px"><b>What breaks:</b> ${escapeHtml(it.what_breaks)}</div>` : ""}
        ${it.regen ? `<div style="font-size:11px;color:var(--muted)"><b>Regen:</b> ${escapeHtml(it.regen)}</div>` : ""}
      </td>
      <td>
        <button class="tiny" onclick="openInFinder('${escapeHtml(it.path)}')">Reveal</button>
        ${action}
      </td>
    </tr>`;
  }).join("");
}

function riskBadgeHtml(risk) {
  if (risk === "danger") return '<span title="DANGER — contains user state, not just cache" style="display:inline-block;padding:2px 6px;border-radius:4px;background:#fee2e2;color:#991b1b;font-size:10px;font-weight:600">🔴 DANGER</span>';
  if (risk === "caution") return '<span title="CAUTION — safe but app may need restart or slow regen" style="display:inline-block;padding:2px 6px;border-radius:4px;background:#fef3c7;color:#92400e;font-size:10px;font-weight:600">🟡 CAUTION</span>';
  return '<span title="SAFE — regenerable from public sources, no app impact" style="display:inline-block;padding:2px 6px;border-radius:4px;background:#d1fae5;color:#065f46;font-size:10px;font-weight:600">🟢 SAFE</span>';
}

async function runDockerPrune() {
  if (!confirm("Run 'docker system prune -f'?\n\nThis removes:\n  • Stopped containers\n  • Dangling images\n  • Unused build cache\n\nThis KEEPS:\n  • Running containers\n  • Used images\n  • All NAMED VOLUMES (your databases stay safe)\n\nFor 'docker system prune -a' (also removes UNUSED images), confirm below then click Run again.")) return;
  setDiskStatus("Running docker prune…", "");
  try {
    const r = await fetch("/disk/docker-prune", { method: "POST",
      headers: {"Content-Type":"application/json"}, body: JSON.stringify({deep: false}) });
    const j = await r.json();
    if (j.ok) {
      alert("docker prune completed:\n\n" + (j.stdout || "(no output)"));
      setDiskStatus("Pruned", "ok");
      setTimeout(() => refreshDisk(true), 800);
    } else {
      alert("docker prune failed: " + (j.error || j.stderr));
      setDiskStatus("Failed", "err");
    }
  } catch (e) {
    alert("Failed: " + e.message);
    setDiskStatus("Failed", "err");
  }
}
function onDiskSelChange(cb) { cb.closest("tr").classList.toggle("selected", cb.checked); }
function toggleAllDisk() {
  const all = document.getElementById("diskSelAll").checked;
  document.querySelectorAll("#diskRows .disk-cb").forEach(cb => {
    cb.checked = all; cb.closest("tr").classList.toggle("selected", all);
  });
}
async function openInFinder(path) {
  await fetch("/reveal?path=" + encodeURIComponent(path)).catch(() => {});
}
async function cleanOneByPath(path) {
  const item = diskItems.find(x => !x._meta && x.path === path);
  if (!item) return;
  if (!confirm(`Delete contents of:\n\n${item.path}\n\n(${item.size_mb} MB) — ${item.desc}\n\nThis is permanent.`)) return;
  await doCleanRequest([item]);
}
async function cleanSelectedDisk() {
  const items = [...document.querySelectorAll("#diskRows .disk-cb:checked")]
    .map(cb => diskItems.find(x => !x._meta && x.path === cb.dataset.path))
    .filter(Boolean);
  if (items.length === 0) { setDiskStatus("Nothing selected", "err"); return; }
  const total = items.reduce((s, x) => s + x.size_mb, 0);
  const lines = items.slice(0, 8).map(x => `  ${x.size_mb} MB  ${x.path.split('/').pop()}`).join("\n");
  if (!confirm(`Clean ${items.length} item(s) — ~${total} MB total?\n\n${lines}${items.length>8?'\n  …':''}\n\nDeletion is permanent.`)) return;
  await doCleanRequest(items);
}

async function doCleanRequest(items) {
  const bar = document.getElementById("diskProgress");
  const fill = document.getElementById("diskProgressBar");
  if (bar) bar.style.display = "block";
  if (fill) fill.style.width = "0%";

  let done = 0, ok = 0, fail = 0;
  // Send one request per item so the user gets real progress updates.
  // /disk-clean accepts an array but we slice it to 1-item batches.
  for (const item of items) {
    const shortName = item.path.split('/').slice(-2).join('/');
    setDiskStatus(`Cleaning ${done + 1}/${items.length}: ${shortName}…`, "");
    try {
      const r = await fetch("/disk-clean", { method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({paths: [{path: item.path, action: item.action}]}) });
      const j = await r.json();
      const itemOk = (j.results || []).every(x => x.ok);
      if (itemOk) ok++; else fail++;
    } catch (e) {
      fail++;
    }
    done++;
    if (fill) fill.style.width = (done / items.length * 100).toFixed(1) + "%";
  }
  setDiskStatus(`Cleaned ${ok} of ${items.length}${fail ? ` — ${fail} failed` : ""}`, fail ? "err" : "ok");
  setTimeout(() => {
    if (bar) bar.style.display = "none";
    refreshDisk(true);
  }, 1500);
}

// --- Column resizing (with localStorage persistence per table) ---
function makeColumnsResizable(tableId) {
  const table = document.getElementById(tableId);
  if (!table) return;
  const cols = table.querySelectorAll("colgroup col");
  if (!cols.length) return;
  // Restore saved widths
  try {
    const saved = JSON.parse(localStorage.getItem("colw_" + tableId) || "[]");
    saved.forEach((w, i) => { if (cols[i] && w) cols[i].style.width = w + "px"; });
  } catch {}
  const ths = table.querySelectorAll("thead th");
  ths.forEach((th, idx) => {
    // Don't add a resizer to the last column
    if (idx >= cols.length - 1) return;
    if (th.querySelector(".col-resizer")) return; // already added
    const h = document.createElement("div");
    h.className = "col-resizer";
    th.appendChild(h);
    h.addEventListener("mousedown", e => {
      e.preventDefault(); e.stopPropagation();
      const startX = e.pageX;
      const col = cols[idx];
      const startW = col.offsetWidth || parseFloat(col.style.width) || 100;
      h.classList.add("dragging");
      document.body.classList.add("col-resizing");
      function onMove(ev) {
        const newW = Math.max(30, startW + (ev.pageX - startX));
        col.style.width = newW + "px";
      }
      function onUp() {
        document.removeEventListener("mousemove", onMove);
        document.removeEventListener("mouseup", onUp);
        h.classList.remove("dragging");
        document.body.classList.remove("col-resizing");
        // Persist widths
        const widths = [...cols].map(c => c.offsetWidth);
        localStorage.setItem("colw_" + tableId, JSON.stringify(widths));
      }
      document.addEventListener("mousemove", onMove);
      document.addEventListener("mouseup", onUp);
    });
  });
}

// Run after first render lays down the headers
const _origRender = render;
render = function() {
  _origRender();
  makeColumnsResizable("procTable");
  makeColumnsResizable("tabTable");
};

refresh();
startHeartbeat();
</script>
</body>
</html>
"""

# --- Server -------------------------------------------------------------

LAST_PING = time.time()
SHUTDOWN = threading.Event()
IDLE_TIMEOUT = 600  # only used when started without --service

# Caches so /kill doesn't re-run a 2s ps+osascript chain
_PROC_CACHE: dict[str, Any] = {"procs": [], "ts": 0.0}
_TAB_CACHE: dict[str, Any] = {"tabs": [], "ts": 0.0}
_DISK_CACHE: dict[str, Any] = {"items": None, "ts": 0.0}
_CACHE_LOCK = threading.Lock()
_PROC_TTL = 4.0
_TAB_TTL = 15.0  # heap correlation is slow — refresh less often
_DISK_TTL = 120.0  # disk scan is slow — cache for 2 min


def cached_disk(force: bool = False) -> list[dict]:
    with _CACHE_LOCK:
        fresh = (time.time() - _DISK_CACHE["ts"] < _DISK_TTL) and _DISK_CACHE["items"] is not None
        if fresh and not force:
            return _DISK_CACHE["items"]
    items = scan_disk()
    with _CACHE_LOCK:
        _DISK_CACHE["items"] = items
        _DISK_CACHE["ts"] = time.time()
    return items


def cached_processes(force: bool = False) -> list[dict]:
    with _CACHE_LOCK:
        fresh = time.time() - _PROC_CACHE["ts"] < _PROC_TTL
        if fresh and not force and _PROC_CACHE["procs"]:
            return _PROC_CACHE["procs"]
    procs = get_processes()
    with _CACHE_LOCK:
        _PROC_CACHE["procs"] = procs
        _PROC_CACHE["ts"] = time.time()
    return procs


def cached_tabs_fast() -> list[dict]:
    """Return tabs immediately. Uses cached heap data if available, otherwise
    fetches just titles+URLs (no heap — fast path)."""
    with _CACHE_LOCK:
        cached = _TAB_CACHE.get("tabs", [])
        ts = _TAB_CACHE.get("ts", 0)
    if cached and time.time() - ts < 60:
        return cached
    return get_browser_tabs(with_heap=False)


def heap_updater_loop() -> None:
    """Background thread: keeps _TAB_CACHE warm with heap data so /data is fast.
    Each iteration may take minutes — never blocks the request path."""
    if SHUTDOWN.wait(2):
        return
    while not SHUTDOWN.is_set():
        try:
            tabs = get_browser_tabs(with_heap=True)
            with _CACHE_LOCK:
                _TAB_CACHE["tabs"] = tabs
                _TAB_CACHE["ts"] = time.time()
        except Exception:
            pass
        if SHUTDOWN.wait(30):
            return


class Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code: int, body: bytes, content_type: str = "text/html") -> None:
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self) -> None:
        global LAST_PING
        LAST_PING = time.time()
        if self.path == "/":
            # Inject a feature-flag script tag before </head>. Time Spent is OFF
            # by default for privacy in distributed installs; enable via:
            #   MHEALTH_ENABLE_TIME_SPENT=1
            # in the launchd plist's EnvironmentVariables.
            enable_time = os.environ.get("MHEALTH_ENABLE_TIME_SPENT") == "1"
            flag_script = f"<script>window.__ENABLE_TIME_SPENT__={'true' if enable_time else 'false'};</script>"
            html_out = HTML.replace("</head>", flag_script + "</head>", 1)
            self._send(200, html_out.encode())
        elif self.path == "/data":
            payload = json.dumps({
                "procs": cached_processes(force=True),
                "tabs": cached_tabs_fast(),
                "summary": system_summary(),
            }).encode()
            self._send(200, payload, "application/json")
        elif self.path == "/disk":
            payload = json.dumps({"items": cached_disk(force=False)}).encode()
            self._send(200, payload, "application/json")
        elif self.path.startswith("/disk?"):
            force = "force=1" in self.path or "refresh=1" in self.path
            payload = json.dumps({"items": cached_disk(force=force)}).encode()
            self._send(200, payload, "application/json")
        elif self.path.startswith("/activity"):
            from urllib.parse import urlparse, parse_qs
            params = parse_qs(urlparse(self.path).query)
            range_key = params.get("range", ["today"])[0]
            payload = json.dumps(time_spent_summary(range_key)).encode()
            self._send(200, payload, "application/json")
        elif self.path == "/readlater":
            payload = json.dumps({"items": _readlater_load()}).encode()
            self._send(200, payload, "application/json")
        elif self.path == "/projects":
            payload = json.dumps({"items": _projects_ensure_seeded()}).encode()
            self._send(200, payload, "application/json")
        elif self.path == "/cloud":
            remotes = []
            for r in rclone_remotes():
                about = rclone_about(r["name"])
                remotes.append({
                    "name": r["name"], "type": r["type"],
                    "total": about.get("total"), "used": about.get("used"), "free": about.get("free"),
                })
            payload = json.dumps({
                "rclone_available": rclone_available(),
                "rclone_path": _which_rclone(),
                "remotes": remotes,
                "archives": _archives_load(),
                "home": os.path.expanduser("~"),
            }).encode()
            self._send(200, payload, "application/json")
        elif self.path.startswith("/cloud/scan"):
            from urllib.parse import urlparse, parse_qs
            params = parse_qs(urlparse(self.path).query)
            tgt = params.get("path", [""])[0]
            if not tgt:
                self._send(400, b'{"ok":false,"error":"path required"}', "application/json")
                return
            # Multi-path: accept comma-separated; classify each and merge
            paths = [p.strip() for p in tgt.split(",") if p.strip()]
            if len(paths) == 1:
                result = classify_folder(paths[0])
            else:
                # Merge results — items prefixed with the parent path so they sort sensibly
                merged_items = []
                merged_totals = {"delete": 0, "archive": 0, "keep": 0, "check": 0}
                ok = True
                errors = []
                for p in paths:
                    r = classify_folder(p)
                    if not r.get("ok"):
                        ok = False
                        errors.append({"path": p, "error": r.get("error")})
                        continue
                    for it in r["items"]:
                        it["scan_root"] = r["target"]
                        merged_items.append(it)
                    for k, v in r["totals_bytes"].items():
                        merged_totals[k] = merged_totals.get(k, 0) + v
                result = {"ok": ok, "target": tgt, "items": merged_items,
                          "totals_bytes": merged_totals, "errors": errors}
            self._send(200, json.dumps(result).encode(), "application/json")
        elif self.path == "/cloud/home-overview":
            self._send(200, json.dumps(scan_home_overview()).encode(), "application/json")
        elif self.path == "/cloud/pick-folder":
            self._send(200, json.dumps(pick_folder()).encode(), "application/json")
        elif self.path == "/system/open-privacy-settings":
            ok = False
            for cmd in [
                ["open", "x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles"],
                ["open", "x-apple.systempreferences:com.apple.settings.PrivacySecurity.extension"],
                ["open", "-b", "com.apple.systempreferences"],
            ]:
                try:
                    r = subprocess.run(cmd, capture_output=True, timeout=5)
                    if r.returncode == 0:
                        ok = True
                        break
                except Exception:
                    continue
            paths = _tcc_paths_for_self()
            self._send(200, json.dumps({"ok": ok, **paths}).encode(), "application/json")
        elif self.path == "/system/reveal-python":
            # Reveal the BEST TCC target — preferring an enclosing .app bundle.
            paths = _tcc_paths_for_self()
            target = paths.get("tcc_target") or paths.get("running_binary") or sys.executable
            try:
                subprocess.Popen(["open", "-R", target])
                ok = True
            except Exception:
                ok = False
            self._send(200, json.dumps({"ok": ok, "path": target, **paths}).encode(), "application/json")
        elif self.path == "/system/tcc-diagnose":
            # Test which protected directories we can actually read right now.
            home = os.path.expanduser("~")
            results = {}
            for name in ("Desktop", "Documents", "Downloads"):
                p = os.path.join(home, name)
                try:
                    os.listdir(p)
                    results[name] = {"ok": True, "error": None}
                except PermissionError as e:
                    results[name] = {"ok": False, "error": e.strerror or str(e)}
                except FileNotFoundError:
                    results[name] = {"ok": None, "error": "directory missing"}
                except Exception as e:
                    results[name] = {"ok": False, "error": str(e)}
            paths = _tcc_paths_for_self()
            self._send(200, json.dumps({"reads": results, **paths}).encode(), "application/json")
        elif self.path == "/snooze":
            self._send(200, json.dumps(snooze_status()).encode(), "application/json")
        elif self.path == "/ping":
            self._send(200, b"ok", "text/plain")
        elif self.path.startswith("/reveal?"):
            from urllib.parse import urlparse, parse_qs
            params = parse_qs(urlparse(self.path).query)
            target = params.get("path", [""])[0]
            # Only reveal if path is in whitelist (under $HOME). Expand "~/" first.
            ok, _ = (False, "")
            if target:
                home = os.path.expanduser("~")
                expanded = os.path.expanduser(target)
                if expanded.startswith(home + os.sep) or expanded == home:
                    try:
                        # If it's a directory, open it; if a file, reveal it.
                        if os.path.isdir(expanded):
                            subprocess.Popen(["open", expanded])
                        else:
                            subprocess.Popen(["open", "-R", expanded])
                        ok = True
                    except Exception:
                        pass
            self._send(200, json.dumps({"ok": ok}).encode(), "application/json")
        else:
            self._send(404, b"not found", "text/plain")

    def do_POST(self) -> None:
        global LAST_PING
        LAST_PING = time.time()
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode() if length else ""

        if self.path == "/kill":
            try:
                pids = json.loads(body).get("pids", [])
            except Exception:
                pids = []
            # Server-side defense: refuse to kill critical processes even if
            # the client somehow asks. Use the cached process list — calling
            # get_processes() here adds 1-3 s of latency to the kill response.
            current = {p["pid"]: p for p in cached_processes(force=False)}
            killed, failed, blocked = 0, 0, 0
            for pid in pids:
                try:
                    p = int(pid)
                except (TypeError, ValueError):
                    failed += 1
                    continue
                info = current.get(p)
                if info and info.get("level") == "critical":
                    blocked += 1
                    continue
                if p == 1 or p == os.getpid():
                    blocked += 1
                    continue
                try:
                    os.kill(p, signal.SIGTERM)
                    killed += 1
                except ProcessLookupError:
                    killed += 1
                except PermissionError:
                    try:
                        os.kill(p, signal.SIGKILL)
                        killed += 1
                    except Exception:
                        failed += 1
                except Exception:
                    failed += 1
            try:
                subprocess.Popen([
                    "terminal-notifier", "-title", "Mac Health",
                    "-subtitle", f"Killed {killed} process(es)",
                    "-message", f"{failed} failed" if failed else "OK",
                    "-sound", "Glass", "-group", "mac-health-watcher",
                ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except FileNotFoundError:
                pass
            self._send(200, json.dumps({"killed": killed, "failed": failed, "blocked": blocked}).encode(),
                       "application/json")

        elif self.path == "/close-tab":
            # Body shape: {"items": [{"app":"Google Chrome","window":1,"tab":2}, ...]}
            try:
                items = json.loads(body).get("items", [])
            except Exception:
                items = []
            by_app: dict[str, list[tuple[int, int]]] = {}
            for it in items:
                try:
                    app = str(it["app"])
                    by_app.setdefault(app, []).append((int(it["window"]), int(it["tab"])))
                except (KeyError, TypeError, ValueError):
                    continue
            closed = 0
            for app, pairs in by_app.items():
                pairs.sort(reverse=True)
                for w, t in pairs:
                    if close_browser_tab(app, w, t):
                        closed += 1
            # Invalidate tab cache so next /data fetches fresh — closed tabs
            # disappear immediately rather than lingering for 60 s
            with _CACHE_LOCK:
                _TAB_CACHE["ts"] = 0.0
            self._send(200, json.dumps({"closed": closed}).encode(), "application/json")

        elif self.path == "/disk-clean":
            try:
                payload = json.loads(body)
                paths = payload.get("paths", [])
            except Exception:
                paths = []
            results = []
            for p in paths:
                path = p.get("path", "")
                action = p.get("action", "delete-contents")
                ok, msg = clean_path(path, action)
                results.append({"path": path, "ok": ok, "msg": msg})
            # Invalidate disk cache so next /disk shows updated sizes
            with _CACHE_LOCK:
                _DISK_CACHE["ts"] = 0.0
            self._send(200, json.dumps({"results": results}).encode(), "application/json")

        elif self.path == "/focus-tab":
            try:
                d = json.loads(body)
                ok = focus_browser_tab(d["app"], int(d["window"]), int(d["tab"]))
            except Exception:
                ok = False
            self._send(200, json.dumps({"ok": ok}).encode(), "application/json")

        elif self.path == "/kill-orphan-servers":
            # Find all other Python processes running mhealth-kill and SIGTERM them.
            mypid = os.getpid()
            killed = 0
            try:
                cmd = subprocess.run(
                    ["ps", "-Aww", "-o", "pid=,command="],
                    capture_output=True, text=True, timeout=5,
                ).stdout
                for line in cmd.splitlines():
                    line = line.strip()
                    sp = line.find(" ")
                    if sp <= 0:
                        continue
                    try:
                        p = int(line[:sp])
                    except ValueError:
                        continue
                    cmdline = line[sp + 1:]
                    if p == mypid or p == 1:
                        continue
                    if "mhealth-kill" in cmdline and "python" in cmdline.lower():
                        try:
                            os.kill(p, signal.SIGTERM)
                            killed += 1
                        except Exception:
                            pass
            except Exception:
                pass
            self._send(200, json.dumps({"killed": killed}).encode(), "application/json")

        elif self.path == "/readlater":
            try:
                items = json.loads(body).get("items", [])
            except Exception:
                items = []
            added = readlater_add(items if isinstance(items, list) else [])
            self._send(200, json.dumps({"added": added}).encode(), "application/json")

        elif self.path == "/projects":
            try:
                payload_in = json.loads(body) if body else {}
            except Exception:
                payload_in = {}
            op = (payload_in.get("op") or "").strip()
            try:
                if op == "add":
                    entry = projects_add(payload_in.get("project") or {})
                    self._send(200, json.dumps({"ok": True, "project": entry}).encode(), "application/json")
                elif op == "update":
                    iid = (payload_in.get("id") or "").strip()
                    entry = projects_update(iid, payload_in.get("project") or {})
                    if entry is None:
                        self._send(404, json.dumps({"ok": False, "error": "not found"}).encode(), "application/json")
                    else:
                        self._send(200, json.dumps({"ok": True, "project": entry}).encode(), "application/json")
                else:
                    self._send(400, json.dumps({"ok": False, "error": "unknown op"}).encode(), "application/json")
            except ValueError as ve:
                self._send(400, json.dumps({"ok": False, "error": str(ve)}).encode(), "application/json")

        elif self.path == "/cloud/archive":
            try:
                payload_in = json.loads(body)
            except Exception:
                self._send(400, b'{"ok":false,"error":"invalid json"}', "application/json"); return
            path = (payload_in.get("path") or "").strip()
            remote = (payload_in.get("remote") or "").strip()
            if not path or not remote:
                self._send(400, b'{"ok":false,"error":"path and remote required"}', "application/json"); return
            # Long-running — rclone copy of GBs can take minutes/hours
            result = archive_path_to_cloud(path, remote)
            self._send(200 if result.get("ok") else 500, json.dumps(result).encode(), "application/json")

        elif self.path == "/cloud/restore":
            try:
                payload_in = json.loads(body)
            except Exception:
                self._send(400, b'{"ok":false,"error":"invalid json"}', "application/json"); return
            iid = (payload_in.get("id") or "").strip()
            keep_remote = bool(payload_in.get("keep_remote", True))
            result = restore_archive(iid, keep_remote=keep_remote)
            self._send(200 if result.get("ok") else 400, json.dumps(result).encode(), "application/json")

        elif self.path == "/snooze":
            try:
                payload_in = json.loads(body) if body else {}
            except Exception:
                payload_in = {}
            secs = int(payload_in.get("seconds", 0))
            self._send(200, json.dumps(snooze_set(secs)).encode(), "application/json")

        elif self.path == "/disk/docker-prune":
            try:
                payload_in = json.loads(body) if body else {}
            except Exception:
                payload_in = {}
            deep = bool(payload_in.get("deep", False))
            result = docker_prune(deep=deep)
            self._send(200 if result.get("ok") else 500, json.dumps(result).encode(), "application/json")

        elif self.path == "/cloud/delete-bulk":
            # Bulk-delete items from the classifier "delete" category
            try:
                payload_in = json.loads(body)
            except Exception:
                self._send(400, b'{"ok":false,"error":"invalid json"}', "application/json"); return
            paths = payload_in.get("paths") or []
            home = os.path.expanduser("~")
            deleted, failed, skipped = 0, [], []
            for p in paths:
                p = os.path.expanduser(p)
                if not (p.startswith(home + os.sep)):
                    skipped.append(p); continue
                try:
                    if os.path.isdir(p) and not os.path.islink(p):
                        import shutil
                        shutil.rmtree(p)
                    else:
                        os.remove(p)
                    deleted += 1
                except Exception as e:
                    failed.append({"path": p, "error": str(e)})
            self._send(200, json.dumps({"ok": True, "deleted": deleted, "failed": failed, "skipped": skipped}).encode(), "application/json")

        elif self.path == "/system/restart":
            # Trigger shutdown; launchd KeepAlive brings us back in ~3s.
            # We respond OK *first*, then exit in a background timer so the
            # response actually reaches the client.
            self._send(200, b'{"ok":true}', "application/json")
            threading.Timer(0.3, lambda: SHUTDOWN.set()).start()
            return

        elif self.path == "/quit":
            self._send(200, b"bye", "text/plain")
            threading.Timer(0.5, lambda: SHUTDOWN.set()).start()
        else:
            self._send(404, b"not found", "text/plain")

    def do_DELETE(self) -> None:
        global LAST_PING
        LAST_PING = time.time()
        from urllib.parse import urlparse, parse_qs
        u = urlparse(self.path)
        if u.path == "/readlater":
            params = parse_qs(u.query)
            iid = params.get("id", [""])[0]
            ok = readlater_remove(iid)
            self._send(200, json.dumps({"ok": ok}).encode(), "application/json")
        elif u.path == "/projects":
            params = parse_qs(u.query)
            iid = params.get("id", [""])[0]
            ok = projects_remove(iid)
            self._send(200, json.dumps({"ok": ok}).encode(), "application/json")
        elif u.path == "/cloud":
            params = parse_qs(u.query)
            iid = params.get("id", [""])[0]
            result = delete_archive(iid)
            self._send(200, json.dumps(result).encode(), "application/json")
        else:
            self._send(404, b"not found", "text/plain")

    def log_message(self, *args: Any) -> None:
        pass


STABLE_PORT_RANGE = range(8765, 8775)


def find_free_port() -> int:
    """Prefer the stable port range (8765-8774) so bookmarks stay valid.
    Sets SO_REUSEADDR on the test socket so we can rebind ports that just
    closed (TIME_WAIT)."""
    for p in STABLE_PORT_RANGE:
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            s.bind(("127.0.0.1", p))
            s.close()
            return p
        except OSError:
            try: s.close()
            except Exception: pass
            continue
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(("127.0.0.1", 0))
    p = s.getsockname()[1]
    s.close()
    return p


def already_running_url() -> str | None:
    """If an mhealth-kill server is already on the stable range, return its URL.
    Caller should just open the browser to that URL instead of starting another."""
    import urllib.request
    for p in STABLE_PORT_RANGE:
        try:
            with urllib.request.urlopen(f"http://127.0.0.1:{p}/ping", timeout=0.3) as r:
                if r.read(8).startswith(b"ok"):
                    return f"http://127.0.0.1:{p}/"
        except Exception:
            continue
    return None


def focus_existing_tab(url: str) -> bool:
    """If any open Chrome/Brave tab matches this URL, activate it and bring the
    browser to the front. Returns True if found. Avoids opening duplicate tabs."""
    # Match by host:port prefix, since the URL might or might not have a path
    from urllib.parse import urlparse
    u = urlparse(url)
    target_prefix = f"{u.scheme}://{u.netloc}"
    for app_name in ("Google Chrome", "Brave Browser"):
        if subprocess.run(["pgrep", "-x", app_name], capture_output=True).returncode != 0:
            continue
        script = (
            f'tell application "{app_name}"\n'
            'set out to ""\n'
            'set wn to 0\n'
            'repeat with w in windows\n'
            '  set wn to wn + 1\n'
            '  set tn to 0\n'
            '  repeat with t in tabs of w\n'
            '    set tn to tn + 1\n'
            '    try\n'
            f'      if URL of t starts with "{target_prefix}" then\n'
            '        set active tab index of w to tn\n'
            '        set index of w to 1\n'
            '        activate\n'
            '        return "1"\n'
            '      end if\n'
            '    end try\n'
            '  end repeat\n'
            'end repeat\n'
            'return ""\n'
            'end tell\n'
        )
        try:
            r = subprocess.run(["osascript", "-e", script],
                               capture_output=True, text=True, timeout=5)
            if r.stdout.strip() == "1":
                return True
        except Exception:
            continue
    return False


def open_or_focus(url: str) -> None:
    """Focus an existing tab if any browser has it; otherwise open a new tab."""
    if focus_existing_tab(url):
        return
    webbrowser.open(url)


def idle_watcher(server: http.server.HTTPServer) -> None:
    while not SHUTDOWN.wait(30):
        if time.time() - LAST_PING > IDLE_TIMEOUT:
            print(f"Idle for >{IDLE_TIMEOUT}s, shutting down.", file=sys.stderr)
            SHUTDOWN.set()
    server.shutdown()


def main() -> int:
    # CLI flags:
    #   --service     run forever (launchd-managed); no browser pop, no idle timeout
    #   --no-browser  start the server but don't open a tab
    args = sys.argv[1:]
    service_mode = "--service" in args
    no_browser = service_mode or "--no-browser" in args

    # If a server is already running on the stable range, just focus the tab.
    # Skip this check in service mode (we ARE the server).
    if not service_mode:
        existing = already_running_url()
        if existing:
            print(f"mhealth-kill already running at {existing}", file=sys.stderr)
            if not no_browser:
                open_or_focus(existing)
            return 0

    port = find_free_port()
    http.server.ThreadingHTTPServer.allow_reuse_address = True
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), Handler)
    if not service_mode:
        # idle-shutdown only when invoked manually; service mode runs forever
        threading.Thread(target=idle_watcher, args=(server,), daemon=True).start()
    threading.Thread(target=server.serve_forever, daemon=True).start()
    threading.Thread(target=heap_updater_loop, daemon=True).start()
    url = f"http://127.0.0.1:{port}/"
    print(f"mhealth-kill server: {url}", file=sys.stderr)
    if not no_browser:
        open_or_focus(url)
    try:
        SHUTDOWN.wait()
    except KeyboardInterrupt:
        pass
    server.shutdown()
    return 0


if __name__ == "__main__":
    sys.exit(main())
