// Helper: render a code block with a copy-to-clipboard button.
function codeBlockWithCopy(code, label) {
  const id = "code-" + Math.random().toString(36).slice(2, 10);
  const safe = escapeHtml(code);
  return `<div style="position:relative;background:#1f2937;color:#f9fafb;border-radius:6px;padding:10px 70px 10px 14px;margin:6px 0;font-family:ui-monospace,Menlo,monospace;font-size:12px;overflow:auto;white-space:pre"><span id="${id}">${safe}</span><button onclick="copyCodeBlock('${id}', this)" style="position:absolute;top:6px;right:6px;background:#374151;color:#f9fafb;border:1px solid #4b5563;border-radius:4px;padding:3px 8px;font-size:11px;cursor:pointer">Copy</button></div>`;
}

async function copyCodeBlock(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  try {
    await navigator.clipboard.writeText(el.textContent);
    const orig = btn.textContent;
    btn.textContent = "✓ Copied";
    btn.style.background = "#065f46";
    setTimeout(() => { btn.textContent = orig; btn.style.background = "#374151"; }, 1500);
  } catch (e) {
    btn.textContent = "Failed";
  }
}

// Helper: a provider chooser card.
function providerCard(id, name, tagline, freeTier, blurb) {
  return `<div onclick="showRecipe('${id}')" style="background:#fff;border:1px solid #fed7aa;border-radius:8px;padding:12px;cursor:pointer;transition:all 0.15s" onmouseover="this.style.borderColor='#f97316';this.style.boxShadow='0 2px 8px rgba(249,115,22,0.15)'" onmouseout="this.style.borderColor='#fed7aa';this.style.boxShadow='none'">
    <div style="font-weight:600;font-size:14px;color:#111827;margin-bottom:2px">${escapeHtml(name)}</div>
    <div style="font-size:11px;color:#f97316;margin-bottom:6px">${escapeHtml(tagline)} · ${escapeHtml(freeTier)}</div>
    <div style="font-size:11px;color:#6b7280;line-height:1.4">${escapeHtml(blurb)}</div>
  </div>`;
}

// Helper: render a provider recipe inline. Called when a card is clicked.
function showRecipe(provider) {
  const el = document.getElementById("providerRecipe");
  el.style.display = "block";
  el.innerHTML = RECIPES[provider] || "";
  el.scrollIntoView({ behavior: "smooth", block: "start" });
}

// Step block builder.
function step(n, title, body) {
  return `<div style="display:flex;gap:12px;margin:10px 0;padding:10px 12px;background:#fff;border:1px solid #fed7aa;border-radius:6px">
    <div style="flex:0 0 28px;height:28px;background:#f97316;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:13px">${n}</div>
    <div style="flex:1;color:#111827;font-size:13px;line-height:1.55"><div style="font-weight:600;margin-bottom:4px">${title}</div>${body}</div>
  </div>`;
}

