      <section>
        <h2>Top shell commands <span style="color:var(--muted);font-weight:400;font-size:12px">(zsh history in range)</span></h2>
        <table>
          <thead><tr><th>Command</th><th class="num">Count</th></tr></thead>
          <tbody id="cmdRows"></tbody>
        </table>
      </section>
      <!-- Bottom-right: empty (CSS grid auto-flow) -->
    </div>
  </div>

<script>
let procs = [], tabs = [], summary = {};
let sortKey = "ram", sortDesc = true;
let autoTimer = null, heartbeat = null;
let maxRam = 1;

document.querySelectorAll("#procTable th[data-key]").forEach(th => {
  th.addEventListener("click", () => sortBy(th.dataset.key));
});

function sortBy(key) {
  if (sortKey === key) sortDesc = !sortDesc;
  else { sortKey = key; sortDesc = (key === "ram" || key === "cpu" || key === "pid"); }
  render();
}

async function refresh() {
  setStatus("Loading…", "");
  try {
    const r = await fetch("/data");
    const j = await r.json();
    procs = j.procs;
    tabs = j.tabs;
    summary = j.summary;
    maxRam = Math.max(1, ...procs.map(p => p.ram));
    const haveHeap = tabs.some(t => t.heap > 0);
    document.getElementById("hintBanner").style.display =
      (tabs.length > 0 && !haveHeap) ? "flex" : "none";
    render();
    setStatus(`${procs.length} processes  ·  ${tabs.length} Chrome tabs  ·  ${new Date().toLocaleTimeString()}`, "ok");
  } catch (e) {
    setStatus("Refresh failed: " + e.message, "err");
  }
}

function setStatus(msg, cls) {
  const el = document.getElementById("status");
  el.textContent = msg;
  el.className = "status " + cls;
}

function render() {
  // Summary
  const s = summary;
  const items = [
    {lbl: "Load", val: s.load, alert: parseFloat(s.load) > 30, warn: parseFloat(s.load) > 10},
    {lbl: "Free RAM", val: s.free_mb + " MB", alert: s.free_mb < 500, warn: s.free_mb < 1000},
    {lbl: "Compressor", val: s.comp_mb + " MB", alert: s.comp_mb > 4000, warn: s.comp_mb > 2000},
    {lbl: "Swap", val: s.swap_mb + " MB", alert: s.swap_mb > 5000, warn: s.swap_mb > 1000},
    {lbl: "Disk", val: s.disk_pct + " (" + s.disk_avail + " free)", alert: parseInt(s.disk_pct) > 90, warn: parseInt(s.disk_pct) > 80},
    {lbl: "Chrome tabs", val: tabs.length}
  ];
  document.getElementById("summary").innerHTML = items.map(i =>
    `<div class="item ${i.alert ? 'alert' : i.warn ? 'warn' : ''}">
       <span class="lbl">${i.lbl}</span><span class="val">${i.val}</span>
     </div>`).join("");

  // Sort processes
  procs.sort((a, b) => {
    let av = a[sortKey], bv = b[sortKey];
    if (typeof av === "string") { av = av.toLowerCase(); bv = bv.toLowerCase(); }
    return (av < bv ? -1 : av > bv ? 1 : 0) * (sortDesc ? -1 : 1);
  });

  document.querySelectorAll("#procTable th[data-key]").forEach(th => {
    th.classList.toggle("sorted", th.dataset.key === sortKey);
    th.querySelector(".arrow").textContent =
      (th.dataset.key === sortKey) ? (sortDesc ? "↓" : "↑") : "";
  });

  const sel = new Set([...document.querySelectorAll("#procRows .row-cb:checked")].map(cb => cb.dataset.pid));
  document.getElementById("procRows").innerHTML = procs.map(p => {
    const barWidth = Math.max(2, (p.ram / maxRam) * 60);
    const isCritical = p.level === "critical";
    const isRisky = p.level === "risky";
    const checked = sel.has(String(p.pid)) ? "checked" : "";
    const badge = p.type ? `<span class="badge ${p.type}">${p.type}</span>` : "";
    const hint = p.hint ? `<span class="hint">${escapeHtml(p.hint)}</span>` : "";
    const desc = p.desc ? `<span class="desc">${escapeHtml(p.desc)}</span>` : "";
    let icon = "", title = "";
    if (isCritical) { icon = "🛡️"; title = "Critical — killing this will break your Mac session. Kill is disabled."; }
    else if (isRisky) { icon = "⚠️"; title = "Risky — will respawn or disrupt. Confirmation required."; }
    const cb = isCritical
      ? `<span class="level-icon" title="${title}">🛡️</span>`
      : `<input type="checkbox" class="row-cb" data-pid="${p.pid}" data-level="${p.level}" ${checked} onchange="onRowSelChange(this)">`;
    const rowCls = (sel.has(String(p.pid)) ? "selected " : "") + (isCritical ? "critical" : isRisky ? "risky" : "");
    const warnCell = icon ? `<td class="warn-cell" title="${title}">${icon}</td>` : `<td></td>`;
    return `<tr class="${rowCls}" data-pid="${p.pid}">
      <td>${cb}</td>
      ${warnCell}
      <td class="num"><span class="ram-bar" style="width:${barWidth}px"></span>${p.ram}</td>
      <td class="num">${p.cpu.toFixed(1)}</td>
      <td title="${escapeHtml(p.name)}">${escapeHtml(p.name)}</td>
      <td class="wrap">${desc}</td>
      <td>${badge}</td>
      <td title="${escapeHtml(p.hint)}">${hint}</td>
      <td class="num pid">${p.pid}</td>
    </tr>`;
  }).join("");

  // Tabs (grouped by browser, then heap desc within each)
  document.getElementById("tabCount").textContent = `(${tabs.length})`;
  const tabSel = new Set([...document.querySelectorAll("#tabRows .tab-cb:checked")].map(cb => cb.dataset.tabkey));
  const sortedTabs = [...tabs].sort((a, b) =>
    (a.browser || "").localeCompare(b.browser || "") ||
    (b.heap || 0) - (a.heap || 0) || a.window - b.window || a.tab - b.tab);
  // Compute duplicate map: normalized URL -> [tab indexes]
  // Normalization: strip fragment + common tracking params + trailing slash + lowercase host
  function normalizeUrl(u) {
    try {
      const url = new URL(u);
      const drop = ["utm_source","utm_medium","utm_campaign","utm_term","utm_content",
                    "fbclid","gclid","mc_cid","mc_eid","ref","ref_src"];
      drop.forEach(k => url.searchParams.delete(k));
      url.hash = "";
      let s = url.origin.toLowerCase() + url.pathname.replace(/\/$/, "") +
              (url.search ? "?" + [...url.searchParams].sort().map(([k,v])=>`${k}=${v}`).join("&") : "");
      return s;
    } catch { return u; }
  }
  const dupGroups = new Map();
  sortedTabs.forEach((t, i) => {
    if (!t.url || t.url.startsWith("chrome://") || t.url.startsWith("brave://")) return;
    const k = normalizeUrl(t.url);
    if (!dupGroups.has(k)) dupGroups.set(k, []);
    dupGroups.get(k).push(i);
  });
  const dupCount = [...dupGroups.values()].reduce((s, arr) => s + Math.max(0, arr.length - 1), 0);
  document.getElementById("dupCount").textContent = dupCount > 0 ? `(${dupCount})` : "";

  const myPort = window.location.port;
  document.getElementById("tabRows").innerHTML = sortedTabs.map((t, i) => {
    const key = `${t.browser}-${t.window}-${t.tab}`;
    const heapMb = t.heap ? Math.round(t.heap / 1024 / 1024) : "—";
    const checked = tabSel.has(key) ? "checked" : "";
    let display = "", isMe = false;
    try {
      const u = new URL(t.url);
      display = (u.hostname === "127.0.0.1" || u.hostname === "localhost")
        ? `${u.hostname}:${u.port}` : u.hostname;
      isMe = (u.hostname === "127.0.0.1" || u.hostname === "localhost") && u.port === myPort;
    } catch { display = t.url; }
    // Determine duplicate status
    const groupKey = normalizeUrl(t.url);
    const group = dupGroups.get(groupKey) || [i];
    let status = "";
    if (group.length > 1) {
      if (group[0] === i) {
        status = `<span class="dup-primary-badge" title="This is the first/primary tab; ${group.length-1} duplicate(s) elsewhere">PRIMARY ×${group.length}</span>`;
      } else {
        status = `<span class="dup-badge" title="Duplicate of an earlier tab — safe to close">DUPLICATE</span>`;
      }
    }
    const tag = `<span class="browser-tag ${t.browser}"><span class="browser-dot ${t.browser}"></span>${t.browser}</span>`;
    const meBadge = isMe ? '<span class="this-tab-badge">THIS WINDOW</span>' : "";
    const isDup = group.length > 1 && group[0] !== i;
    const closeBtn = isMe
      ? `<button class="tiny" disabled title="Closing this tab will quit the tool">Close</button>`
      : `<button class="tiny" onclick="closeOneTab('${escapeHtml(t.browser_app)}', ${t.window}, ${t.tab})">Close</button>`;
    return `<tr class="${tabSel.has(key) ? 'selected ' : ''}${isMe ? 'this-tab' : ''} ${isDup ? 'is-dup' : ''}" data-tabkey="${key}" data-windowidx="${i}">
      <td>${isMe ? "" : `<input type="checkbox" class="tab-cb" data-tabkey="${key}" data-app="${escapeHtml(t.browser_app)}" data-window="${t.window}" data-tab="${t.tab}" data-url="${escapeHtml(t.url)}" data-title="${escapeHtml(t.title)}" ${checked} onchange="onTabSelChange(this)">`}</td>
      <td>${tag}</td>
      <td class="col-tab">W${t.window}T${t.tab}</td>
      <td>${status}</td>
      <td class="tab-title-cell">
        <div class="title">${escapeHtml(t.title)}${meBadge}</div>
        <div class="url">${escapeHtml(display)}</div>
      </td>
      <td class="num">${heapMb}</td>
      <td>
        <button class="tiny" onclick="focusOneTab('${escapeHtml(t.browser_app)}', ${t.window}, ${t.tab})">Open</button>
        ${isMe
          ? `<button class="tiny" disabled title="Can't save the dashboard tab itself">Save</button>`
          : `<button class="tiny" onclick="saveAndCloseOne('${escapeHtml(t.browser)}', '${escapeHtml(t.browser_app)}', ${t.window}, ${t.tab}, '${escapeHtml(t.url)}', '${escapeHtml(t.title)}')" title="Save to Read Later AND close this tab">Save</button>`}
        ${closeBtn}
      </td>
    </tr>`;
  }).join("");
  // Stash for closeAllDuplicates / save handlers
  window._lastTabs = sortedTabs;
  window._dupGroups = dupGroups;
}

async function closeAllDuplicates() {
  const groups = window._dupGroups || new Map();
  const tabs = window._lastTabs || [];
  const items = [];
  for (const [k, idxs] of groups) {
    if (idxs.length <= 1) continue;
    // Skip the primary (idxs[0]) — close the rest
    for (let i = 1; i < idxs.length; i++) {
      const t = tabs[idxs[i]];
      if (!t) continue;
      items.push({app: t.browser_app, window: t.window, tab: t.tab});
    }
  }
  if (items.length === 0) {
    setStatus("No duplicates found", "ok");
    return;
  }
  if (!confirm(`Close ${items.length} duplicate tab(s)?\n\nKeeping the first occurrence of each URL.`)) return;
  const r = await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"}, body: JSON.stringify({items}) });
  const j = await r.json();
  setStatus(`Closed ${j.closed} duplicate(s)`, "ok");
  setTimeout(refresh, 500);
}

async function saveAndCloseOne(browser, app, window, tab, url, title) {
  // Optimistic: remove row immediately
  _removeTabRow(app, window, tab);
  setStatus("Saving & closing…", "");
  await fetch("/readlater", { method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({items:[{browser, url, title}]}) });
  await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({items:[{app, window, tab}]}) });
  setStatus("Saved & closed", "ok");
  setTimeout(refresh, 600);
}

function _selectedTabItems() {
  return [...document.querySelectorAll("#tabRows .tab-cb:checked")].map(cb => ({
    browser: cb.closest("tr").querySelector(".browser-tag")?.textContent.trim() || "",
    app: cb.dataset.app,
    window: parseInt(cb.dataset.window),
    tab: parseInt(cb.dataset.tab),
    url: cb.dataset.url,
    title: cb.dataset.title,
  }));
}
async function saveAndCloseSelected() {
  const checked = [...document.querySelectorAll("#tabRows .tab-cb:checked")];
  const items = _selectedTabItems();
  if (items.length === 0) { setStatus("No tabs selected", "err"); return; }
  // Optimistic: remove rows immediately
  checked.forEach(cb => cb.closest("tr").remove());
  setStatus(`Saving & closing ${items.length}…`, "");
  await fetch("/readlater", { method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({items: items.map(x => ({browser: x.browser, url: x.url, title: x.title}))}) });
  const closeItems = items.map(x => ({app: x.app, window: x.window, tab: x.tab}));
  const r = await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"}, body: JSON.stringify({items: closeItems}) });
  const j = await r.json();
  setStatus(`Saved ${items.length} & closed ${j.closed} tab(s)`, "ok");
  setTimeout(refresh, 600);
}

async function refreshReadLater() {
  const el = document.getElementById("rlStatus");
  el.textContent = "Loading…"; el.className = "status";
  try {
    const r = await fetch("/readlater");
    const j = await r.json();
    document.getElementById("rlCount").textContent = `(${j.items.length})`;
    document.getElementById("rlRows").innerHTML = j.items.length === 0
      ? `<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:24px">Empty. Save tabs from the Browser Tabs view.</td></tr>`
      : j.items.map(it => {
          let host = "";
          try { host = new URL(it.url).hostname; } catch {}
          const dt = new Date(it.saved_at).toLocaleString([], {month:"short",day:"numeric",hour:"numeric",minute:"2-digit"});
          return `<tr>
            <td style="color:var(--muted);font-size:12px">${escapeHtml(dt)}</td>
            <td><span class="browser-tag ${it.browser}"><span class="browser-dot ${it.browser}"></span>${it.browser}</span></td>
            <td class="tab-title-cell"><div class="title">${escapeHtml(it.title)}</div><div class="url"><a href="${escapeHtml(it.url)}" target="_blank" rel="noopener" style="color:var(--muted)">${escapeHtml(host || it.url)}</a></div></td>
            <td>
              <button class="tiny" onclick="openReadLater('${escapeHtml(it.id)}', '${escapeHtml(it.url)}')">Open</button>
              <button class="tiny" onclick="openAndRemoveRl('${escapeHtml(it.id)}', '${escapeHtml(it.url)}')">Open &amp; Remove</button>
              <button class="tiny" onclick="removeReadLater('${escapeHtml(it.id)}')">Remove</button>
            </td>
          </tr>`;
        }).join("");
    el.textContent = "Updated " + new Date().toLocaleTimeString();
    el.className = "status ok";
  } catch (e) {
    el.textContent = "Failed: " + e.message;
    el.className = "status err";
  }
}
function openReadLater(id, url) { window.open(url, "_blank"); }
async function openAndRemoveRl(id, url) {
  window.open(url, "_blank");
  await removeReadLater(id);
}
async function removeReadLater(id) {
  await fetch("/readlater?id=" + encodeURIComponent(id), { method: "DELETE" });
  refreshReadLater();
}
async function exportReadLater() {
  const r = await fetch("/readlater");
  const j = await r.json();
  const blob = new Blob([JSON.stringify(j.items, null, 2)], {type: "application/json"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "read-later-" + new Date().toISOString().slice(0,10) + ".json";
  a.click();
}

async function closeOtherMhealthTabs() {
  const myPort = window.location.port;
  // Identify other 127.0.0.1 tabs whose title looks like Mac Health
  const candidates = tabs.filter(t => {
    try {
      const u = new URL(t.url);
      if (u.hostname !== "127.0.0.1" && u.hostname !== "localhost") return false;
      if (u.port === myPort) return false;
      return /Mac Health/i.test(t.title) || /Kill Processes/i.test(t.title);
    } catch { return false; }
  });
  if (candidates.length === 0) {
    setStatus("No other Mac Health tabs found", "ok");
    return;
  }
  if (!confirm(`Close ${candidates.length} other Mac Health tab(s)?\n\n` +
               candidates.map(t => `  • ${t.browser} W${t.window}T${t.tab} — ${t.title}`).join("\n"))) return;
  const items = candidates.map(t => ({app: t.browser_app, window: t.window, tab: t.tab}));
  const r = await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"}, body: JSON.stringify({items}) });
  const j = await r.json();
  // Also kill the orphan server processes (they're still running on other ports)
  await fetch("/kill-orphan-servers", { method: "POST" }).catch(() => {});
  setStatus(`Closed ${j.closed} tab(s) + signaled orphan servers`, "ok");
  setTimeout(refresh, 600);
}

function escapeHtml(s) {
  return String(s || "").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

function onRowSelChange(cb) { cb.closest("tr").classList.toggle("selected", cb.checked); }
function onTabSelChange(cb) { cb.closest("tr").classList.toggle("selected", cb.checked); }

function toggleAll() {
  const all = document.getElementById("selAll").checked;
  document.querySelectorAll("#procRows .row-cb").forEach(cb => {
    cb.checked = all; cb.closest("tr").classList.toggle("selected", all);
  });
}
function toggleAllTabs() {
  const all = document.getElementById("tabSelAll").checked;
  document.querySelectorAll("#tabRows .tab-cb").forEach(cb => {
    cb.checked = all; cb.closest("tr").classList.toggle("selected", all);
  });
}

async function killSelected() {
  const checked = [...document.querySelectorAll("#procRows .row-cb:checked")];
  const pids = checked.map(cb => cb.dataset.pid);
  if (pids.length === 0) { setStatus("Nothing selected", "err"); return; }

  // Risky-process gate: any in selection?
  const risky = checked.filter(cb => cb.dataset.level === "risky").map(cb => {
    const p = procs.find(x => String(x.pid) === cb.dataset.pid);
    return p ? `${p.name} — ${p.desc || ''}` : cb.dataset.pid;
  });

  if (document.getElementById("confirm").checked || risky.length > 0) {
    const names = pids.slice(0, 6).map(pid => {
      const p = procs.find(x => String(x.pid) === pid);
      const tag = p && p.level === "risky" ? " ⚠️" : "";
      return p ? `${p.name} (${p.ram}MB)${tag}${p.hint ? ' — ' + p.hint : ''}` : pid;
    });
    const more = pids.length > 6 ? `\n…and ${pids.length - 6} more` : "";
    let msg = `Kill ${pids.length} process(es)?\n\n${names.join("\n")}${more}`;
    if (risky.length > 0) {
      msg += `\n\n⚠️ ${risky.length} risky process(es): may disrupt UI / cause respawn.`;
    }
    if (!confirm(msg)) return;
  }
  // Detect Chrome renderers — warn user the tab will show "Aw, snap!"
  const rendererCount = checked.filter(cb => {
    const p = procs.find(x => String(x.pid) === cb.dataset.pid);
    return p && p.type === "renderer";
  }).length;
  if (rendererCount > 0) {
    const ok = confirm(
      `${rendererCount} of your selection ${rendererCount === 1 ? "is a Chrome renderer" : "are Chrome renderers"}.\n\n` +
      `Killing a renderer leaves the Chrome tab showing "Aw, snap!" — the tab itself stays open.\n\n` +
      `For a clean tab close, cancel and use the Chrome Tabs section below.\n\n` +
      `Continue with kill?`
    );
    if (!ok) return;
  }

  pids.forEach(pid => {
    const tr = document.querySelector(`#procRows tr[data-pid="${pid}"]`);
    if (tr) tr.classList.add("killing");
  });
  setStatus(`Killing ${pids.length}…`, "");
  try {
    const r = await fetch("/kill", { method: "POST",
      headers: {"Content-Type": "application/json"}, body: JSON.stringify({pids}) });
    const j = await r.json();
    let msg = `✓ Killed ${j.killed}`;
    if (j.failed) msg += `, ${j.failed} failed`;
    if (j.blocked) msg += `, ${j.blocked} blocked (critical)`;
    setStatus(msg, j.failed || j.blocked ? "err" : "ok");
    setTimeout(refresh, 250);
  } catch (e) {
    setStatus("Kill failed: " + e.message, "err");
  }
}

function _removeTabRow(app, window, tab) {
  // Find the row by matching its checkbox attributes
  const cb = document.querySelector(
    `#tabRows .tab-cb[data-app="${app.replace(/"/g, '\\"')}"][data-window="${window}"][data-tab="${tab}"]`
  );
  if (cb) cb.closest("tr").remove();
  // Also handle the dashboard's own row (no checkbox) by matching tabkey
  const tabkey = (typeof arguments[3] === "string") ? arguments[3] : null;
  if (tabkey) {
    const tr = document.querySelector(`#tabRows tr[data-tabkey="${tabkey}"]`);
    if (tr) tr.remove();
  }
}

async function closeOneTab(app, window, tab) {
  // Optimistic: remove row immediately
  _removeTabRow(app, window, tab);
  setStatus("Closing tab…", "");
  const r = await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({items: [{app, window, tab}]}) });
  const j = await r.json();
  setStatus(`Closed ${j.closed} tab`, j.closed ? "ok" : "err");
  setTimeout(refresh, 600);  // background re-sync
}
async function focusOneTab(app, window, tab) {
  await fetch("/focus-tab", { method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({app, window, tab}) });
}
async function closeSelectedTabs() {
  const checked = [...document.querySelectorAll("#tabRows .tab-cb:checked")];
  const items = checked.map(cb =>
    ({app: cb.dataset.app, window: parseInt(cb.dataset.window), tab: parseInt(cb.dataset.tab)}));
  if (items.length === 0) { setStatus("No tabs selected", "err"); return; }
  // Optimistic: remove rows immediately
  checked.forEach(cb => cb.closest("tr").remove());
  setStatus(`Closing ${items.length} tab(s)…`, "");
  const r = await fetch("/close-tab", { method: "POST",
    headers: {"Content-Type":"application/json"}, body: JSON.stringify({items}) });
  const j = await r.json();
  setStatus(`Closed ${j.closed} tab(s)`, "ok");
  setTimeout(refresh, 600);
}

function toggleAuto() {
  if (document.getElementById("autoRefresh").checked) {
    if (!autoTimer) autoTimer = setInterval(refresh, 5000);
  } else { clearInterval(autoTimer); autoTimer = null; }
}

function startHeartbeat() {
  heartbeat = setInterval(() => fetch("/ping").catch(() => {}), 15000);
}
window.addEventListener("beforeunload", () => {
  navigator.sendBeacon("/quit", "");
});

// --- Tab switcher ---
function switchTab(name) {
  // Back-compat: old bookmarks. "space"/"disk" → caches (the most likely intent).
  if (name === "space" || name === "disk") name = "caches";
  if (name === "cloud") name = "cloudsetup";
  document.querySelectorAll(".tab").forEach(t => t.classList.toggle("active", t.dataset.pane === name));
  document.querySelectorAll(".pane").forEach(p => p.classList.toggle("active", p.id === "pane-" + name));
  if (name === "caches") refreshDisk(false);
  if (name === "archive") refreshCloud();
  if (name === "cloudsetup") refreshCloud();
  if (name === "time") refreshActivity();
  if (name === "readlater") refreshReadLater();
  if (name === "projects") refreshProjects();
  if (name === "processes" || name === "tabs") refresh();
}

// --- Notification snooze -------------------------------------------------

function toggleSnoozeMenu() {
  const m = document.getElementById("snoozeMenu");
  m.style.display = m.style.display === "none" ? "block" : "none";
}
document.addEventListener("click", (e) => {
  const wrap = document.getElementById("snoozeWrap");
  if (wrap && !wrap.contains(e.target)) {
    const m = document.getElementById("snoozeMenu");
    if (m) m.style.display = "none";
  }
});

async function setSnooze(seconds) {
  document.getElementById("snoozeMenu").style.display = "none";
  try {
    const r = await fetch("/snooze", {
      method: "POST", headers: {"Content-Type":"application/json"},
      body: JSON.stringify({seconds}),
    });
    const j = await r.json();
    renderSnooze(j);
  } catch (e) {
    alert("Snooze failed: " + e.message);
  }
}

function setSnoozeTomorrow() {
  const now = new Date();
  const target = new Date(now);
  target.setDate(target.getDate() + 1);
  target.setHours(9, 0, 0, 0);
  const secs = Math.floor((target - now) / 1000);
  setSnooze(secs);
}

function renderSnooze(j) {
  const status = document.getElementById("snoozeStatus");
  const btn = document.getElementById("snoozeBtn");
  if (!j || !j.snoozed) {
    status.style.display = "inline-block";
    status.textContent = "🔔 Alerts on";
    status.style.background = "#d1fae5";
    status.style.color = "#065f46";
    btn.textContent = "Snooze ▾";
    return;
  }
  const remaining = j.remaining_seconds;
  const untilDate = new Date(j.until * 1000);
  const hh = String(untilDate.getHours()).padStart(2, "0");
  const mm = String(untilDate.getMinutes()).padStart(2, "0");
  let label;
  if (remaining > 24 * 3600) {
    const days = Math.ceil(remaining / 86400);
    label = `🔕 Snoozed ${days}d`;
  } else if (remaining > 3600) {
    const hrs = Math.round(remaining / 3600);
    label = `🔕 Snoozed (until ${hh}:${mm})`;
  } else {
    const mins = Math.ceil(remaining / 60);
    label = `🔕 Snoozed (${mins}m left)`;
  }
  status.style.display = "inline-block";
  status.textContent = label;
  status.style.background = "#fed7aa";
  status.style.color = "#7c2d12";
  btn.textContent = "Change ▾";
}

async function refreshSnooze() {
  try {
    const r = await fetch("/snooze");
    renderSnooze(await r.json());
  } catch (e) {
    // silent — chip just stays hidden
  }
}

// Refresh on load + every 30 s (so the countdown updates without manual refresh)
refreshSnooze();
setInterval(refreshSnooze, 30 * 1000);

// Time Spent tab is hidden by default for privacy. Server injects
// window.__ENABLE_TIME_SPENT__ based on the MHEALTH_ENABLE_TIME_SPENT env var.
// When true, reveal the tab.
if (window.__ENABLE_TIME_SPENT__) {
  const t = document.getElementById("timeSpentTab");
  if (t) t.style.display = "";
}

// Hover effect for menu items
document.addEventListener("mouseover", (e) => {
  if (e.target.classList && e.target.classList.contains("snoozeItem")) {
    e.target.style.background = "#f3f4f6";
  }
});
document.addEventListener("mouseout", (e) => {
  if (e.target.classList && e.target.classList.contains("snoozeItem")) {
    e.target.style.background = "";
  }
});

