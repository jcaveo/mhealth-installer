def _safe_path(p: str) -> str:
    return os.path.expanduser(p)


def _du_mb(path: str, timeout: int = 30) -> int:
    if not os.path.exists(path):
        return -1
    try:
        out = subprocess.run(
            ["du", "-sk", path],
            capture_output=True, text=True, timeout=timeout,
        ).stdout
        return int(out.split()[0]) // 1024
    except Exception:
        return -1


def scan_disk() -> list[dict]:
    """Returns a list of candidate items. May take 5-30 seconds — caller caches."""
    items: list[dict] = []
    for cand in DISK_CANDIDATES:
        path = _safe_path(cand["path"])
        if cand["action"] == "scan-children":
            # List subdirs and report each one over 50 MB
            if not os.path.isdir(path):
                continue
            try:
                children = os.listdir(path)
            except PermissionError:
                continue
            for child in children:
                child_path = os.path.join(path, child)
                if not os.path.isdir(child_path):
                    continue
                size_mb = _du_mb(child_path, timeout=10)
                if size_mb >= 50:
                    items.append({
                        "path": child_path,
                        "size_mb": size_mb,
                        "category": cand["category"],
                        "risk": cand.get("risk", "safe"),
                        "level": cand.get("risk", "safe"),  # back-compat
                        "action": "delete-contents",
                        "desc": cand["desc"] + f" ({child})",
                        "what_breaks": cand.get("what_breaks", ""),
                        "regen": cand.get("regen", ""),
                    })
        else:
            size_mb = _du_mb(path, timeout=20)
            if size_mb < 0:
                continue
            if size_mb < 10:
                continue
            items.append({
                "path": path,
                "size_mb": size_mb,
                "category": cand["category"],
                "risk": cand.get("risk", "safe"),
                "level": cand.get("risk", "safe"),  # back-compat
                "action": cand["action"],
                "desc": cand["desc"],
                "what_breaks": cand.get("what_breaks", ""),
                "regen": cand.get("regen", ""),
            })
    items.sort(key=lambda x: x["size_mb"], reverse=True)

    # Disk volume info for header
    total_gb = used_gb = avail_gb = 0
    pct = "?"
    try:
        df_out = subprocess.run(
            ["df", "-k", "/System/Volumes/Data"],
            capture_output=True, text=True,
        ).stdout.splitlines()[1].split()
        total_gb = int(df_out[1]) // 1024 // 1024
        used_gb = int(df_out[2]) // 1024 // 1024
        avail_gb = int(df_out[3]) // 1024 // 1024
        pct = df_out[4]
    except Exception:
        pass
    return [{"_meta": {"total_gb": total_gb, "used_gb": used_gb,
                       "avail_gb": avail_gb, "pct": pct}}] + items


# --- Read Later storage --------------------------------------------------

READLATER_DIR = os.path.expanduser("~/Library/Application Support/mac-health-watcher")
READLATER_PATH = os.path.join(READLATER_DIR, "read-later.json")
_READLATER_LOCK = threading.Lock()


def _readlater_load() -> list[dict]:
    if not os.path.exists(READLATER_PATH):
        return []
    try:
        with open(READLATER_PATH) as f:
            data = json.load(f)
        return data if isinstance(data, list) else []
    except Exception:
        return []


def _readlater_save(items: list[dict]) -> None:
    os.makedirs(READLATER_DIR, exist_ok=True)
    tmp = READLATER_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(items, f, indent=2)
    os.replace(tmp, READLATER_PATH)


def readlater_add(items: list[dict]) -> int:
    """Append items, dedupe by URL. Returns number of new entries added."""
    with _READLATER_LOCK:
        existing = _readlater_load()
        existing_urls = {e.get("url") for e in existing}
        added = 0
        now = datetime.datetime.now().isoformat(timespec="seconds")
        for it in items:
            url = (it.get("url") or "").strip()
            if not url or url in existing_urls:
                continue
            entry = {
                "id": str(int(time.time() * 1000)) + "-" + str(added),
                "url": url,
                "title": (it.get("title") or "").strip()[:300],
                "browser": (it.get("browser") or "").strip(),
                "saved_at": now,
            }
            existing.insert(0, entry)
            existing_urls.add(url)
            added += 1
        _readlater_save(existing)
        return added


def readlater_remove(item_id: str) -> bool:
    with _READLATER_LOCK:
        existing = _readlater_load()
        new = [e for e in existing if e.get("id") != item_id]
        if len(new) == len(existing):
            return False
        _readlater_save(new)
        return True


# --- Projects tracker (Claude-built work) --------------------------------

PROJECTS_PATH = os.path.join(READLATER_DIR, "projects.json")
_PROJECTS_LOCK = threading.Lock()
VALID_STATES = {"in_progress", "finished", "unfinished"}

# Seeded only when projects.json doesn't exist yet. After that, the user
# owns the list entirely — re-running the tool never overwrites their data.
_SEED_PROJECTS = [
    {
        "name": "mhealth ecosystem",
        "description": "Mac health watcher + dashboard + activity logger + Read Later + Disk Cleanup + this Projects tab. Distributed as a signed-or-unsigned .pkg.",
        "state": "in_progress",
        "path": "~/Documents/projects/mhealth-installer",
        "pending": "Apple Developer ID signing + notarization; migrate user's own Mac from com.jc.* to com.mhealth.* LaunchAgents.",
    },
    {
        "name": "session-auto-rename",
        "description": "Auto-renames Claude Code resume sessions to readable 'Project: Task' strings via a Stop hook. Has a recursion guard (CLAUDE_SKIP_RENAME_HOOK).",
        "state": "finished",
        "path": "~/.claude/scripts/rename-session.py",
        "pending": "",
    },
]


def _projects_load() -> list[dict]:
    if not os.path.exists(PROJECTS_PATH):
        return []
    try:
        with open(PROJECTS_PATH) as f:
            data = json.load(f)
        return data if isinstance(data, list) else []
    except Exception:
        return []


def _projects_save(items: list[dict]) -> None:
    os.makedirs(READLATER_DIR, exist_ok=True)
    tmp = PROJECTS_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(items, f, indent=2)
    os.replace(tmp, PROJECTS_PATH)


def _projects_ensure_seeded() -> list[dict]:
    """First-run: write seed entries. Subsequent runs: leave the file alone."""
    if os.path.exists(PROJECTS_PATH):
        return _projects_load()
    now = datetime.datetime.now().strftime("%Y-%m-%d")
    seeded = []
    for i, p in enumerate(_SEED_PROJECTS):
        seeded.append({
            "id": str(int(time.time() * 1000)) + "-" + str(i),
            "name": p["name"],
            "description": p["description"],
            "state": p["state"],
            "path": p["path"],
            "pending": p["pending"],
            "last_work_date": now,
            "created_at": now,
        })
    _projects_save(seeded)
    return seeded


def _normalize_project(raw: dict, existing: dict | None = None) -> dict:
    """Validate + clean a project dict. existing is the prior version (for updates)."""
    state = (raw.get("state") or "in_progress").strip()
    if state not in VALID_STATES:
        state = "in_progress"
    today = datetime.datetime.now().strftime("%Y-%m-%d")
    date = (raw.get("last_work_date") or "").strip()
    if not date:
        date = today
    return {
        "id": (existing or {}).get("id") or (str(int(time.time() * 1000)) + "-" + str(random.randint(0, 9999))),
        "name": (raw.get("name") or "").strip()[:120],
        "description": (raw.get("description") or "").strip()[:500],
        "state": state,
        "path": (raw.get("path") or "").strip()[:500],
        "pending": (raw.get("pending") or "").strip()[:500],
        "last_work_date": date[:10],
        "created_at": (existing or {}).get("created_at") or today,
    }


def projects_add(raw: dict) -> dict:
    with _PROJECTS_LOCK:
        items = _projects_load()
        entry = _normalize_project(raw)
        if not entry["name"]:
            raise ValueError("name is required")
        items.insert(0, entry)
        _projects_save(items)
        return entry


def projects_update(item_id: str, raw: dict) -> dict | None:
    with _PROJECTS_LOCK:
        items = _projects_load()
        for i, e in enumerate(items):
            if e.get("id") == item_id:
                merged = {**e, **raw}
                items[i] = _normalize_project(merged, existing=e)
                _projects_save(items)
                return items[i]
        return None


def projects_remove(item_id: str) -> bool:
    with _PROJECTS_LOCK:
        items = _projects_load()
        new = [e for e in items if e.get("id") != item_id]
        if len(new) == len(items):
            return False
        _projects_save(new)
        return True


# --- Cloud Archive (rclone wrapper + folder classifier + registry) ------

ARCHIVES_PATH = os.path.join(READLATER_DIR, "archives.json")
_ARCHIVES_LOCK = threading.Lock()
ARCHIVE_REMOTE_PREFIX = "mhealth-archive"  # all archives live under <remote>:mhealth-archive/<id>/

# Top-level dirs/files that are regenerable (npm install / docker pull / etc.)
REGENERABLE_DIRS = {
    "node_modules", "dist", "build", ".next", "target", ".venv", "venv",
    "__pycache__", ".pytest_cache", ".mypy_cache", ".gradle", ".cache",
    "out", ".turbo", ".parcel-cache", "DerivedData", ".dart_tool",
    "Pods", ".bundle", ".sass-cache", "vendor",  # vendor varies; PHP/Go projects regenerate it
}
# Extensions where a single large file is worth archiving rather than keeping local
ARCHIVE_EXTENSIONS = {
    ".pdf", ".png", ".jpg", ".jpeg", ".gif", ".mp4", ".mov", ".mkv", ".avi", ".webm",
    ".zip", ".tar", ".gz", ".tgz", ".7z", ".rar", ".bz2",
    ".csv", ".parquet", ".sqlite", ".db", ".dmg", ".iso", ".pkg",
    ".psd", ".ai", ".sketch", ".fig", ".afdesign", ".afphoto",
    ".bin", ".pth", ".onnx", ".gguf", ".safetensors",  # ML weights
}
# Tiny config/source files — always KEEP
KEEP_PATTERNS = {
    ".git", ".gitignore", ".gitattributes", ".env.example", "Dockerfile",
    "docker-compose.yml", "package.json", "package-lock.json", "pnpm-lock.yaml",
    "yarn.lock", "requirements.txt", "pyproject.toml", "tsconfig.json",
    "Makefile", "README.md", "LICENSE", "CHANGELOG.md", "DECISIONS.md",
}
SOURCE_EXTENSIONS = {
    ".py", ".js", ".ts", ".tsx", ".jsx", ".go", ".rs", ".rb", ".php",
    ".java", ".kt", ".swift", ".c", ".cpp", ".h", ".hpp", ".html", ".css",
    ".scss", ".vue", ".svelte", ".md", ".txt", ".yml", ".yaml", ".json",
    ".toml", ".sh", ".bash", ".zsh", ".sql", ".lua", ".dart",
}


def _git_last_commit_age_days(repo: str) -> int | None:
    """Days since the last commit on the current branch. Returns None if not a git
    repo, no commits, or git unavailable. Bounded to 3 s so a stuck git can't hang scans."""
    if not os.path.isdir(os.path.join(repo, ".git")):
        return None
    try:
        r = subprocess.run(
            ["git", "-C", repo, "log", "-1", "--format=%ct"],
            capture_output=True, text=True, timeout=3,
        )
        if r.returncode != 0 or not r.stdout.strip():
            return None
        last_ts = int(r.stdout.strip())
        return max(0, (int(time.time()) - last_ts) // 86400)
    except Exception:
        return None


def _du_bytes(path: str, max_seconds: float = 8.0) -> int:
    """Walk a path and sum file sizes. Bounded by wall time to avoid hangs."""
    deadline = time.time() + max_seconds
    total = 0
    try:
        if os.path.isfile(path):
            return os.path.getsize(path)
        for dirpath, dirnames, filenames in os.walk(path, followlinks=False):
            if time.time() > deadline:
                break
            for f in filenames:
                fp = os.path.join(dirpath, f)
                try:
                    st = os.lstat(fp)
                    if (st.st_mode & 0o170000) == 0o100000:  # regular file
                        total += st.st_size
                except OSError:
                    continue
    except Exception:
        pass
    return total


def classify_folder(target: str) -> dict:
    """Walk top-level entries of `target` and classify each."""
    target = os.path.expanduser(target)
    if not os.path.isdir(target):
        return {"ok": False, "error": "not a directory"}

    items = []
    home = os.path.expanduser("~")
    # Refuse to scan outside $HOME
    if not (target == home or target.startswith(home + os.sep)):
        return {"ok": False, "error": "path must be under $HOME"}

    try:
        entries = sorted(os.listdir(target))
    except PermissionError as e:
        # On macOS, scanning ~/Documents / ~/Desktop / ~/Downloads under launchd
        # often hits TCC (Transparency, Consent & Control). The server's Python
        # interpreter needs explicit consent in System Settings.
        hint = ""
        protected = ("/Documents/", "/Desktop/", "/Downloads/")
        if any(p in target + "/" for p in protected):
            hint = (" — macOS likely blocking access via privacy controls. "
                    "Grant 'Files and Folders' (or 'Full Disk Access') to the "
                    "Python interpreter at System Settings → Privacy & Security.")
        return {"ok": False, "error": f"permission denied{hint} ({e.strerror or e})"}

    for name in entries:
        full = os.path.join(target, name)
        try:
            st = os.lstat(full)
        except OSError:
            continue
        is_link = os.path.islink(full)
        is_dir = (not is_link) and os.path.isdir(full)
        ext = os.path.splitext(name)[1].lower()
        # Pre-compute size once (for files: stat; for dirs: walk-bounded; for links: 0)
        if is_link:
            size_bytes = 0
        elif is_dir:
            size_bytes = _du_bytes(full, max_seconds=4.0)
        else:
            size_bytes = st.st_size

        # Classify
        category = "keep"
        reason = "leave alone by default"

        if is_link:
            reason = "symlink — leave alone"
        elif is_dir and name in REGENERABLE_DIRS:
            category = "delete"
            reason = f"'{name}' is regenerable (npm install / docker pull / build)"
        elif name in KEEP_PATTERNS:
            reason = "project metadata / configuration"
        elif not is_dir and ext in SOURCE_EXTENSIONS:
            reason = "source code"
        elif not is_dir and ext in ARCHIVE_EXTENSIONS:
            if size_bytes >= 10 * 1024 * 1024:
                category = "archive"
                reason = f"large {ext} asset, non-regenerable"
            else:
                reason = "small asset, not worth archiving"
        elif is_dir:
            if os.path.isdir(os.path.join(full, ".git")):
                age = _git_last_commit_age_days(full)
                if age is None:
                    category = "check"
                    reason = "git repo — couldn't read history. Verify before archiving."
                elif age >= 180:
                    category = "archive"
                    reason = f"inactive — last commit {age}d ago (>6 months). Likely safe to archive."
                elif age >= 90:
                    category = "archive"
                    reason = f"cold — last commit {age}d ago (>3 months). Consider archiving."
                elif age >= 30:
                    category = "check"
                    reason = f"recent — last commit {age}d ago. Confirm no untracked work first."
                else:
                    category = "check"
                    reason = f"active — last commit {age}d ago. Probably still in use."
            elif size_bytes >= 100 * 1024 * 1024:
                category = "archive"
                reason = f"large folder ({_fmt_bytes(size_bytes)}), no .git inside"
            else:
                reason = "small folder, not worth archiving"

        items.append({
            "name": name,
            "path": full,
            "is_dir": is_dir,
            "size_bytes": size_bytes,
            "category": category,
            "reason": reason,
        })

    # Aggregate
    totals = {"delete": 0, "archive": 0, "keep": 0, "check": 0}
    for it in items:
        totals[it["category"]] = totals.get(it["category"], 0) + it["size_bytes"]

    return {
        "ok": True,
        "target": target,
        "items": items,
        "totals_bytes": totals,
    }


def _fmt_bytes(n: int) -> str:
    if n < 1024: return f"{n} B"
    if n < 1024 ** 2: return f"{n/1024:.1f} KB"
    if n < 1024 ** 3: return f"{n/1024**2:.1f} MB"
    return f"{n/1024**3:.2f} GB"


# --- rclone wrapper ------------------------------------------------------

def _which_rclone() -> str | None:
    for p in (
        "/opt/homebrew/bin/rclone", "/usr/local/bin/rclone",
        "/opt/local/bin/rclone", "/usr/bin/rclone",
    ):
        if os.path.isfile(p) and os.access(p, os.X_OK):
            return p
    # PATH fallback
    try:
        r = subprocess.run(["which", "rclone"], capture_output=True, text=True, timeout=2)
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    return None


def rclone_available() -> bool:
    return _which_rclone() is not None


def rclone_remotes() -> list[dict]:
    """List configured remotes with type. Free/used pulled on demand via rclone_about()."""
    exe = _which_rclone()
    if not exe:
        return []
    try:
        r = subprocess.run([exe, "listremotes", "--long"], capture_output=True, text=True, timeout=5)
        out = r.stdout.strip()
    except Exception:
        return []
    remotes = []
    for line in out.splitlines():
        # Format: "name: type"
        line = line.strip()
        if not line or ":" not in line:
            continue
        name_part, _, type_part = line.partition(":")
        # rclone listremotes --long returns "name: type" where name has no trailing colon
        remotes.append({"name": name_part.strip(), "type": type_part.strip()})
    return remotes


def rclone_about(remote: str) -> dict:
    """Returns {total, used, free} in bytes, or {} if unavailable for that backend."""
    exe = _which_rclone()
    if not exe:
        return {}
    try:
        r = subprocess.run(
            [exe, "about", f"{remote}:", "--json"],
            capture_output=True, text=True, timeout=10,
        )
        if r.returncode != 0:
            return {}
        return json.loads(r.stdout) if r.stdout.strip() else {}
    except Exception:
        return {}


def rclone_run(args: list[str], timeout: int = 3600) -> tuple[int, str, str]:
    exe = _which_rclone()
    if not exe:
        return (127, "", "rclone not installed")
    try:
        r = subprocess.run([exe] + args, capture_output=True, text=True, timeout=timeout)
        return (r.returncode, r.stdout, r.stderr)
    except subprocess.TimeoutExpired:
        return (124, "", f"timeout after {timeout}s")
    except Exception as e:
        return (1, "", str(e))


# --- Archive registry ----------------------------------------------------

def _archives_load() -> list[dict]:
    if not os.path.exists(ARCHIVES_PATH):
        return []
    try:
        with open(ARCHIVES_PATH) as f:
            data = json.load(f)
        return data if isinstance(data, list) else []
    except Exception:
        return []


def _archives_save(items: list[dict]) -> None:
    os.makedirs(READLATER_DIR, exist_ok=True)
    tmp = ARCHIVES_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(items, f, indent=2)
    os.replace(tmp, ARCHIVES_PATH)


def archives_add(entry: dict) -> dict:
    with _ARCHIVES_LOCK:
        items = _archives_load()
        items.insert(0, entry)
        _archives_save(items)
        return entry


def archives_remove(entry_id: str) -> dict | None:
    with _ARCHIVES_LOCK:
        items = _archives_load()
        for i, e in enumerate(items):
            if e.get("id") == entry_id:
                removed = items.pop(i)
                _archives_save(items)
                return removed
        return None


def archive_path_to_cloud(local_path: str, remote: str) -> dict:
    """Atomic: rclone copy → rclone check → record → rm local. Returns result dict."""
    local_path = os.path.expanduser(local_path)
    home = os.path.expanduser("~")
    if not (local_path.startswith(home + os.sep) or local_path == home):
        return {"ok": False, "error": "path must be under $HOME"}
    if not os.path.exists(local_path):
        return {"ok": False, "error": "path does not exist"}
    if not rclone_available():
        return {"ok": False, "error": "rclone not installed"}
    remotes = {r["name"] for r in rclone_remotes()}
    if remote not in remotes:
        return {"ok": False, "error": f"remote '{remote}' not configured"}

    entry_id = f"{int(time.time()*1000)}-{random.randint(0, 9999)}"
    base = os.path.basename(local_path.rstrip("/")) or "root"
    remote_path = f"{ARCHIVE_REMOTE_PREFIX}/{entry_id}-{base}"
    target = f"{remote}:{remote_path}"
    size_before = _du_bytes(local_path, max_seconds=30.0)

    # 1. Copy
    rc, _, err = rclone_run(["copy", local_path, target, "--transfers", "4", "--checkers", "8"])
    if rc != 0:
        return {"ok": False, "error": f"rclone copy failed: {err[:300]}", "stage": "copy"}

    # 2. Verify with one-way check (every local file must exist on remote with matching hash/size)
    rc, _, err = rclone_run(["check", local_path, target, "--one-way"])
    if rc != 0:
        # Don't delete local — clean up the partial upload
        rclone_run(["purge", target], timeout=300)
        return {"ok": False, "error": f"rclone check failed (upload incomplete): {err[:300]}", "stage": "check"}

    # 3. Record
    entry = {
        "id": entry_id,
        "original_path": local_path,
        "name": base,
        "remote": remote,
        "remote_path": remote_path,
        "size_bytes": size_before,
        "archived_at": datetime.datetime.now().isoformat(timespec="seconds"),
        "is_dir": os.path.isdir(local_path),
    }
    archives_add(entry)

    # 4. Delete local — only after registry is updated
    try:
        if os.path.isdir(local_path) and not os.path.islink(local_path):
            import shutil
            shutil.rmtree(local_path)
        else:
            os.remove(local_path)
    except Exception as e:
        # Cloud copy is verified + registered — local delete failed but archive is safe.
        return {"ok": True, "warning": f"archived OK but local delete failed: {e}", "entry": entry}

    return {"ok": True, "entry": entry}


def restore_archive(entry_id: str, *, keep_remote: bool = True) -> dict:
    """Download from cloud back to original_path. Refuses to overwrite existing files."""
    if not rclone_available():
        return {"ok": False, "error": "rclone not installed"}
    items = _archives_load()
    entry = next((e for e in items if e.get("id") == entry_id), None)
    if not entry:
        return {"ok": False, "error": "archive not found"}

    local_path = entry["original_path"]
    if os.path.exists(local_path):
        return {"ok": False, "error": f"refusing to overwrite — {local_path} already exists"}

    src = f"{entry['remote']}:{entry['remote_path']}"
    # rclone copy src dst where dst is the destination directory.
    # For a folder archive, we want the contents under local_path itself.
    os.makedirs(local_path, exist_ok=True) if entry.get("is_dir") else os.makedirs(os.path.dirname(local_path), exist_ok=True)
    dst = local_path if entry.get("is_dir") else os.path.dirname(local_path)
    rc, _, err = rclone_run(["copy", src, dst, "--transfers", "4"])
    if rc != 0:
        return {"ok": False, "error": f"rclone copy failed: {err[:300]}"}

    # If file archive (not dir), the file should now be at the right place
    if not keep_remote:
        rclone_run(["purge", src], timeout=300)
        archives_remove(entry_id)

    return {"ok": True, "entry": entry, "kept_remote": keep_remote}


def delete_archive(entry_id: str) -> dict:
    """Remove from cloud + remove registry entry. Does not touch any local file."""
    if not rclone_available():
        return {"ok": False, "error": "rclone not installed"}
    items = _archives_load()
    entry = next((e for e in items if e.get("id") == entry_id), None)
    if not entry:
        return {"ok": False, "error": "archive not found"}
    src = f"{entry['remote']}:{entry['remote_path']}"
    rc, _, err = rclone_run(["purge", src], timeout=300)
    # Even if purge fails (e.g. remote already gone), drop the registry entry on user's call.
    archives_remove(entry_id)
    return {"ok": rc == 0, "purge_error": err[:300] if rc != 0 else None}


# --- Time-spent analysis -------------------------------------------------

ACTIVITY_LOG = os.path.expanduser("~/Library/Logs/mhealth-activity.csv")
IDLE_THRESHOLD_SEC = 60  # rows where idle_sec >= this don't count as "active"


def _parse_activity_rows(since: datetime.datetime, until: datetime.datetime) -> list[dict]:
    if not os.path.exists(ACTIVITY_LOG):
        return []
    import csv as _csv
    rows: list[dict] = []
    try:
        with open(ACTIVITY_LOG, newline="") as f:
            for r in _csv.DictReader(f):
                ts_str = r.get("timestamp", "")
                if not ts_str:
                    continue
                try:
                    ts = datetime.datetime.fromisoformat(ts_str)
                except ValueError:
                    continue
                if since <= ts <= until:
                    rows.append({
                        "ts": ts, "app": r.get("app", ""),
                        "window": r.get("window_title", ""),
                        "idle": int(r.get("idle_sec") or 0),
                        "browser_tab": r.get("browser_tab", ""),
                        "browser_url": r.get("browser_url", ""),
                    })
    except Exception:
        pass
    return rows


def _aggregate_app_time(rows: list[dict]) -> tuple[list[dict], int, int]:
    """Returns (top_apps, active_minutes, total_minutes).
    Each entry: 1 minute (each row is one tick). Idle rows excluded from active."""
    from collections import Counter
    active = Counter()
    total = 0
    active_total = 0
    for r in rows:
        total += 1
        if r["idle"] < IDLE_THRESHOLD_SEC and r["app"]:
            active[r["app"]] += 1
            active_total += 1
    out = [{"app": a, "minutes": m, "pct": round(100 * m / max(1, active_total))}
           for a, m in active.most_common(15)]
    return out, active_total, total


def _browser_time_by_host(activity_rows: list[dict]) -> dict[str, int]:
    """Count activity-log rows per browser host within the active window.
    Each row represents ~1 minute frontmost on that URL — only count when the user
    was NOT idle (idle_sec < threshold). Returns {host: minutes}."""
    from collections import Counter
    from urllib.parse import urlparse
    counter: Counter = Counter()
    for r in activity_rows:
        try:
            idle = int(r.get("idle_sec") or 0)
        except (TypeError, ValueError):
            idle = 0
        if idle >= IDLE_THRESHOLD_SEC:
            continue
        url = (r.get("browser_url") or "").strip()
        if not url:
            continue
        try:
            host = (urlparse(url).hostname or "").lower()
        except Exception:
            continue
        if not host or host in ("127.0.0.1", "localhost"):
            continue
        if host.startswith("www."):
            host = host[4:]
        counter[host] += 1   # 1 row = 1 minute (activity logger runs every 60 s)
    return dict(counter)


def _browser_history_top_sites(since_unix: int, top: int = 20) -> list[dict]:
    """Aggregate visits across ALL Chrome + Brave profiles."""
    from collections import Counter
    import glob
    import shutil
    import sqlite3
    import tempfile
    from urllib.parse import urlparse

    counter: Counter = Counter()
    # Chrome timestamps: microseconds since 1601-01-01
    epoch_offset_us = 11644473600 * 1_000_000
    cutoff_us = since_unix * 1_000_000 + epoch_offset_us

    roots = [
        ("Chrome", os.path.expanduser("~/Library/Application Support/Google/Chrome")),
        ("Brave",  os.path.expanduser("~/Library/Application Support/BraveSoftware/Brave-Browser")),
    ]
    db_paths: list[tuple[str, str]] = []
    for name, root in roots:
        if not os.path.isdir(root):
            continue
        # Each profile is a subdir with a History sqlite db. Skip Guest Profile.
        for db in glob.glob(os.path.join(root, "*", "History")):
            if "Guest Profile" in db:
                continue
            db_paths.append((name, db))

    for name, db in db_paths:
        try:
            tmp = tempfile.mktemp(suffix=".db")
            shutil.copy(db, tmp)
            with sqlite3.connect(tmp) as conn:
                # Count REAL visits in the time window via the visits table
                rows = conn.execute(
                    "SELECT u.url, COUNT(v.visit_time) AS n "
                    "FROM urls u JOIN visits v ON v.url = u.id "
                    "WHERE v.visit_time > ? "
                    "GROUP BY u.url ORDER BY n DESC LIMIT 500",
                    (cutoff_us,),
                ).fetchall()
            try:
                os.unlink(tmp)
            except FileNotFoundError:
                pass
            for url, n in rows:
                try:
                    host = (urlparse(url).hostname or url).lower()
                except Exception:
                    host = url.lower()
                if not host or host in ("127.0.0.1", "localhost"):
                    continue
                # Strip leading www. so foo.com and www.foo.com merge
                if host.startswith("www."):
                    host = host[4:]
                counter[(host, name)] += n
        except Exception:
            continue

    return [{"host": h, "browser": b, "visits": c}
            for (h, b), c in counter.most_common(top)]


def _shell_history_top(since_unix: int, top: int = 20) -> list[dict]:
    """Parse zsh extended-history format `: <ts>:<dur>;<cmd>`."""
    from collections import Counter
    path = os.path.expanduser("~/.zsh_history")
    if not os.path.exists(path):
        return []
    counter: Counter = Counter()
    try:
        with open(path, "rb") as f:
            for raw in f:
                try:
                    line = raw.decode("utf-8")
                except UnicodeDecodeError:
                    line = raw.decode("latin-1", errors="replace")
                m = re.match(r"^: (\d+):\d+;(.+)$", line)
                if not m:
                    continue
                ts = int(m.group(1))
                if ts < since_unix:
                    continue
                cmd = m.group(2).strip()
                # First word as the command bucket
                first = cmd.split()[0] if cmd else ""
                if first:
                    counter[first] += 1
    except Exception:
        pass
    return [{"command": c, "count": n} for c, n in counter.most_common(top)]


def time_spent_summary(range_key: str) -> dict:
    now = datetime.datetime.now()
    if range_key == "today":
        since = now.replace(hour=0, minute=0, second=0, microsecond=0)
    elif range_key == "yesterday":
        y = now - datetime.timedelta(days=1)
        since = y.replace(hour=0, minute=0, second=0, microsecond=0)
        now = y.replace(hour=23, minute=59, second=59)
    elif range_key == "7days":
        since = now - datetime.timedelta(days=7)
    elif range_key == "30days":
        since = now - datetime.timedelta(days=30)
    else:
        since = now.replace(hour=0, minute=0, second=0, microsecond=0)

    rows = _parse_activity_rows(since, now)
    apps, active_min, total_min = _aggregate_app_time(rows)
    sites = _browser_history_top_sites(int(since.timestamp()))
    # Merge in time-spent per host from activity log (one row ≈ 1 minute frontmost)
    time_by_host = _browser_time_by_host(rows)
    for s in sites:
        s["minutes"] = time_by_host.get(s["host"], 0)
    cmds = _shell_history_top(int(since.timestamp()))
    activity_log_exists = os.path.exists(ACTIVITY_LOG)
    return {
        "range": range_key,
        "since": since.isoformat(),
        "active_minutes": active_min,
        "total_minutes": total_min,
        "idle_minutes": total_min - active_min,
        "apps": apps,
        "top_sites": sites,
        "top_commands": cmds,
        "activity_log_exists": activity_log_exists,
        "rows_collected": len(rows),
    }


def clean_path(path: str, action: str) -> tuple[bool, str]:
    """Returns (success, message). Validates path is in the whitelist."""
    expanded = os.path.realpath(_safe_path(path))
    home = os.path.expanduser("~")
    # Defense: must live under $HOME, must match a whitelisted root
    if not expanded.startswith(home + os.sep):
        return False, "path is not under user home"
    whitelist_roots = [_safe_path(c["path"]) for c in DISK_CANDIDATES]
    whitelist_real = [os.path.realpath(p) for p in whitelist_roots if os.path.exists(p)]
    if not any(expanded == r or expanded.startswith(r + os.sep) for r in whitelist_real):
        return False, "path is not on the cleanup whitelist"
    if not os.path.exists(expanded):
        return False, "path does not exist"

    try:
        if action == "empty-trash":
            # Walk Trash and remove everything inside
            for entry in os.listdir(expanded):
                full = os.path.join(expanded, entry)
                if os.path.isdir(full):
                    subprocess.run(["rm", "-rf", full], check=False, timeout=120)
                else:
                    try:
                        os.remove(full)
                    except Exception:
                        pass
            return True, "emptied"
        elif action == "delete-contents":
            # Delete the directory contents (keep the directory itself)
            for entry in os.listdir(expanded):
                full = os.path.join(expanded, entry)
                subprocess.run(["rm", "-rf", full], check=False, timeout=120)
            return True, "cleaned"
        else:
            return False, f"action {action} not supported"
    except Exception as e:
        return False, str(e)


def docker_prune(deep: bool = False) -> dict:
    """Run `docker system prune` safely. Never -a --volumes (that wipes named volumes).
    deep=True adds -a (removes UNUSED images too, but still keeps named volumes).
    """
    # Try common docker locations (Docker Desktop puts it in /usr/local/bin)
    docker = None
    for cand in ("/usr/local/bin/docker", "/opt/homebrew/bin/docker"):
        if os.path.isfile(cand) and os.access(cand, os.X_OK):
            docker = cand
            break
    if not docker:
        try:
            r = subprocess.run(["which", "docker"], capture_output=True, text=True, timeout=2)
            if r.returncode == 0 and r.stdout.strip():
                docker = r.stdout.strip()
        except Exception:
            pass
    if not docker:
        return {"ok": False, "error": "docker CLI not found on PATH"}

    args = [docker, "system", "prune", "-f"]
    if deep:
        args.append("-a")
    try:
        r = subprocess.run(args, capture_output=True, text=True, timeout=300)
        return {
            "ok": r.returncode == 0,
            "stdout": r.stdout[-2000:],
            "stderr": r.stderr[-2000:],
        }
    except subprocess.TimeoutExpired:
        return {"ok": False, "error": "docker prune timed out after 5 minutes"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def pick_folder() -> dict:
    """Pop the macOS folder picker via AppleScript. Returns selected POSIX path or None."""
    script = (
        'set f to choose folder with prompt "Pick a folder to scan with mhealth"\n'
        'return POSIX path of f'
    )
    try:
        r = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True, text=True, timeout=120,
        )
        if r.returncode != 0:
            # User cancelled (returncode 1) is the common path
            return {"ok": False, "cancelled": "User canceled." in (r.stderr or "")}
        path = r.stdout.strip()
        # Strip trailing slash for consistency with how scan handles paths
        if path.endswith("/") and len(path) > 1:
            path = path[:-1]
        return {"ok": True, "path": path}
    except subprocess.TimeoutExpired:
        return {"ok": False, "error": "picker timed out"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def scan_home_overview() -> dict:
    """Quick overview of top-level $HOME directories with size. Helps locate scan targets fast."""
    home = os.path.expanduser("~")
    skip = {"Library", "Applications", ".Trash"}  # noisy / not useful as scan targets
    items = []
    try:
        for name in sorted(os.listdir(home)):
            if name.startswith(".") and name not in {".config", ".cache", ".local"}:
                continue
            if name in skip:
                continue
            full = os.path.join(home, name)
            try:
                st = os.lstat(full)
            except OSError:
                continue
            is_link = os.path.islink(full)
            is_dir = (not is_link) and os.path.isdir(full)
            if is_link:
                continue
            if is_dir:
                size = _du_bytes(full, max_seconds=10.0)
            else:
                size = st.st_size
            items.append({"name": name, "path": full, "is_dir": is_dir, "size_bytes": size})
    except PermissionError:
        return {"ok": False, "error": "permission denied scanning $HOME"}
    items.sort(key=lambda x: x["size_bytes"], reverse=True)
    return {"ok": True, "home": home, "items": items}


# --- TCC: figure out what binary macOS actually validates against -------

def _tcc_paths_for_self() -> dict:
    """Return all the candidate paths involved in TCC for this running process.
    Reports:
      sys_executable       – what Python thinks it is (often a symlink)
      sys_executable_real  – os.path.realpath of the above
      running_binary       – what `ps` says is actually running (may differ on macOS
                             when Python re-execs through Python.app)
      tcc_target           – best path to grant TCC against; prefers the
                             enclosing .app bundle if one exists.
    """
    import shlex
    info: dict = {
        "sys_executable": sys.executable,
        "sys_executable_real": os.path.realpath(sys.executable),
        "running_binary": None,
        "tcc_target": None,
        "running_app_bundle": None,
    }
    # `ps -o comm=` returns the first arg of the running process (the actual exec path)
    try:
        r = subprocess.run(
            ["ps", "-p", str(os.getpid()), "-o", "comm="],
            capture_output=True, text=True, timeout=2,
        )
        if r.returncode == 0:
            info["running_binary"] = r.stdout.strip() or None
    except Exception:
        pass

    # Walk up the directory tree looking for an enclosing .app bundle.
    # If we're running inside Python.app/Contents/MacOS/Python, the .app is the
    # right TCC target — macOS shows that as the app icon in Privacy & Security.
    def _enclosing_app(path: str) -> str | None:
        d = os.path.dirname(path)
        while d and d != "/":
            if d.endswith(".app"):
                return d
            d = os.path.dirname(d)
        return None

    for candidate in (info["running_binary"], info["sys_executable_real"], info["sys_executable"]):
        if not candidate:
            continue
        app = _enclosing_app(candidate)
        if app:
            info["running_app_bundle"] = app
            info["tcc_target"] = app
            break

    # No .app found → grant to the running binary itself.
    if info["tcc_target"] is None:
        info["tcc_target"] = info["running_binary"] or info["sys_executable_real"] or info["sys_executable"]

    return info


# --- Notification snooze --------------------------------------------------

SNOOZE_FILE = os.path.join(READLATER_DIR, "snoozed-until")


def snooze_status() -> dict:
    """Returns {snoozed: bool, until: epoch|None, remaining_seconds: int}"""
    if not os.path.exists(SNOOZE_FILE):
        return {"snoozed": False, "until": None, "remaining_seconds": 0}
    try:
        with open(SNOOZE_FILE) as f:
            until = int(f.read().strip())
    except Exception:
        return {"snoozed": False, "until": None, "remaining_seconds": 0}
    now = int(time.time())
    remaining = until - now
    return {"snoozed": remaining > 0, "until": until, "remaining_seconds": max(0, remaining)}


def snooze_set(seconds: int) -> dict:
    """Set snooze. seconds<=0 cancels."""
    os.makedirs(READLATER_DIR, exist_ok=True)
    if seconds <= 0:
        try:
            if os.path.exists(SNOOZE_FILE):
                os.remove(SNOOZE_FILE)
        except Exception:
            pass
        return snooze_status()
    until = int(time.time()) + int(seconds)
    tmp = SNOOZE_FILE + ".tmp"
    with open(tmp, "w") as f:
        f.write(str(until))
    os.replace(tmp, SNOOZE_FILE)
    return snooze_status()


def system_summary() -> dict:
    s: dict[str, Any] = {}
    try:
        load = subprocess.run(["uptime"], capture_output=True, text=True).stdout
        s["load"] = re.search(r"load averages?:\s*([\d.]+)", load).group(1)
    except Exception:
        s["load"] = "?"
    try:
        vm = subprocess.run(["vm_stat"], capture_output=True, text=True).stdout
        free_pages = int(re.search(r"Pages free:\s+(\d+)", vm).group(1))
        comp_pages = int(re.search(r"Pages occupied by compressor:\s+(\d+)", vm).group(1))
        s["free_mb"] = free_pages * 16384 // 1024 // 1024
        s["comp_mb"] = comp_pages * 16384 // 1024 // 1024
    except Exception:
        s["free_mb"] = s["comp_mb"] = 0
    try:
        swap_line = subprocess.run(["sysctl", "-n", "vm.swapusage"], capture_output=True, text=True).stdout
        s["swap_mb"] = int(float(re.search(r"used\s*=\s*([\d.]+)M", swap_line).group(1)))
    except Exception:
        s["swap_mb"] = 0
    try:
        df_out = subprocess.run(["df", "-h", "/System/Volumes/Data"], capture_output=True, text=True).stdout
        s["disk_pct"] = df_out.splitlines()[1].split()[4]
        s["disk_avail"] = df_out.splitlines()[1].split()[3]
    except Exception:
        s["disk_pct"] = "?"
        s["disk_avail"] = "?"
    return s


