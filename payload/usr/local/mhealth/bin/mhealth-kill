CHROME_TYPE_INFO: dict[str, tuple[str, str]] = {
    "browser":     ("Browser main process — kill closes the entire browser", "risky"),
    "renderer":    ("Browser tab content (one or more tabs share this)", "safe"),
    "gpu-process": ("Browser GPU compositor (will respawn)", "safe"),
    "utility":     ("Browser utility worker (network/audio/storage)", "safe"),
    "extension":   ("Browser extension background process", "safe"),
    "network":     ("Browser network service — kills active downloads/streams", "risky"),
}

# Browsers we know how to query via AppleScript. Add more here.
KNOWN_BROWSERS: list[dict[str, str]] = [
    {"name": "Google Chrome", "app": "Google Chrome", "short": "Chrome",
     "match": "Google Chrome", "color": "#4285F4"},
    {"name": "Brave Browser", "app": "Brave Browser", "short": "Brave",
     "match": "Brave Browser", "color": "#FB542B"},
]


def classify(name: str, ctype: str) -> tuple[str, str]:
    """Return (description, level) for a process."""
    if ctype and ctype in CHROME_TYPE_INFO:
        return CHROME_TYPE_INFO[ctype]
    if name in PROCESS_INFO:
        return PROCESS_INFO[name]
    # Heuristic catches
    if name.endswith("d") and name.islower() and len(name) > 3:
        # daemons — usually risky to kill
        return (f"{name} (system daemon — uncertain impact)", "risky")
    if "Helper" in name or "Renderer" in name:
        return ("Application helper process", "safe")
    return ("", "safe")


# --- Process collection ---------------------------------------------------

def get_processes(min_ram_mb: int = 20, top_n: int = 80) -> list[dict]:
    out = subprocess.run(
        ["ps", "-Aceo", "pid,rss,pcpu,comm", "-m"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()

    # Single ps call to get all command lines, build pid -> cmdline map.
    # This replaces N subprocess calls (one per Chrome process) with one.
    cmdlines: dict[int, str] = {}
    try:
        cmd_out = subprocess.run(
            ["ps", "-Aww", "-o", "pid=,command="],
            capture_output=True, text=True, timeout=3,
        ).stdout
        for line in cmd_out.splitlines():
            line = line.strip()
            sp = line.find(" ")
            if sp <= 0:
                continue
            try:
                cmdlines[int(line[:sp])] = line[sp + 1:]
            except ValueError:
                pass
    except Exception:
        pass

    procs: list[dict] = []
    for line in out[1:top_n + 1]:
        parts = line.split(None, 3)
        if len(parts) < 4:
            continue
        try:
            pid = int(parts[0])
            rss_kb = int(parts[1])
            cpu = float(parts[2])
            name = parts[3].strip()
        except ValueError:
            continue
        rss_mb = rss_kb // 1024
        if rss_mb < min_ram_mb:
            continue

        ptype = ""
        ext_id = ""
        browser = ""
        # Detect any Chromium-based browser by process name
        if ("Chrome" in name or name.startswith("Google") or
                "Brave" in name or "Microsoft Edge" in name or
                "Vivaldi" in name or "Opera" in name):
            cmd = cmdlines.get(pid, "")
            m = re.search(r"--type=([a-zA-Z-]+)", cmd)
            ptype = m.group(1) if m else "browser"
            if "--extension-process" in cmd:
                ptype = "extension"
                eid = re.search(r"--extension-id=([a-z0-9]+)", cmd)
                if eid:
                    ext_id = eid.group(1)
            # Normalize the display name to its canonical browser name
            if "Brave" in name:
                name = "Brave Browser"
                browser = "Brave"
            elif "Microsoft Edge" in name:
                name = "Microsoft Edge"
                browser = "Edge"
            elif "Vivaldi" in name:
                name = "Vivaldi"
                browser = "Vivaldi"
            else:
                name = "Google Chrome"
                browser = "Chrome"

        desc, level = classify(name, ptype)
        proc = {"pid": pid, "ram": rss_mb, "cpu": cpu, "name": name,
                "type": ptype, "browser": browser, "hint": "",
                "desc": desc, "level": level}
        if ext_id:
            proc["hint"] = f"extension:{ext_id[:8]}"
        if pid == 1:
            proc["level"] = "critical"
        procs.append(proc)
    procs.sort(key=lambda p: p["ram"], reverse=True)

    # Per-browser renderer → tab correlation using cached heap data.
    # Match heaviest heap to heaviest RSS, within each browser.
    try:
        with _CACHE_LOCK:
            tabs = list(_TAB_CACHE.get("tabs", []))
        for b_short in {"Chrome", "Brave", "Edge", "Vivaldi"}:
            renderers = sorted(
                [p for p in procs if p.get("browser") == b_short
                 and p["type"] == "renderer" and not p["hint"]],
                key=lambda p: p["ram"], reverse=True,
            )
            t_for_b = sorted(
                [t for t in tabs if t.get("browser") == b_short and t.get("heap", 0) > 0],
                key=lambda t: t["heap"], reverse=True,
            )
            for renderer, tab in zip(renderers, t_for_b):
                renderer["hint"] = f"~ {tab['title'][:50]}"
    except Exception:
        pass

    return procs


def _tabs_script(app_name: str, with_heap: bool) -> str:
    if with_heap:
        return (
            f'tell application "{app_name}"\n'
            'set out to ""\n'
            'set wn to 0\n'
            'repeat with w in windows\n'
            'set wn to wn + 1\n'
            'set tn to 0\n'
            'repeat with t in tabs of w\n'
            'set tn to tn + 1\n'
            'try\n'
            'set theTitle to title of t\n'
            'set theURL to URL of t\n'
            'set theHeap to "0"\n'
            'try\n'
            'set theHeap to (execute t javascript "(performance.memory && performance.memory.usedJSHeapSize) || 0") as text\n'
            'end try\n'
            'set out to out & wn & "|" & tn & "|" & theHeap & "|" & theTitle & "|" & theURL & linefeed\n'
            'end try\n'
            'end repeat\n'
            'end repeat\n'
            'return out\n'
            'end tell\n'
        )
    return (
        f'tell application "{app_name}"\n'
        'set out to ""\n'
        'set wn to 0\n'
        'repeat with w in windows\n'
        'set wn to wn + 1\n'
        'set tn to 0\n'
        'repeat with t in tabs of w\n'
        'set tn to tn + 1\n'
        'try\n'
        'set out to out & wn & "|" & tn & "|0|" & (title of t) & "|" & (URL of t) & linefeed\n'
        'end try\n'
        'end repeat\n'
        'end repeat\n'
        'return out\n'
        'end tell\n'
    )


def get_browser_tabs(with_heap: bool = False) -> list[dict]:
    """Aggregate tabs from all known running browsers.
    Each tab dict has: browser (short name), window, tab, title, url, heap."""
    all_tabs: list[dict] = []
    for b in KNOWN_BROWSERS:
        if subprocess.run(["pgrep", "-x", b["app"]], capture_output=True).returncode != 0:
            continue
        try:
            script = _tabs_script(b["app"], with_heap)
            timeout = 180 if with_heap else 8
            result = subprocess.run(
                ["osascript", "-e", script],
                capture_output=True, text=True, timeout=timeout,
            )
            for line in result.stdout.splitlines():
                parts = line.split("|", 4)
                if len(parts) >= 5:
                    try:
                        all_tabs.append({
                            "browser": b["short"],
                            "browser_app": b["app"],
                            "window": int(parts[0]),
                            "tab": int(parts[1]),
                            "heap": int(parts[2]) if parts[2].isdigit() else 0,
                            "title": parts[3],
                            "url": parts[4],
                        })
                    except ValueError:
                        pass
        except Exception:
            continue
    return all_tabs


def close_browser_tab(app_name: str, window: int, tab: int) -> bool:
    try:
        subprocess.run(
            ["osascript", "-e",
             f'tell application "{app_name}" to close tab {tab} of window {window}'],
            capture_output=True, timeout=5, check=True,
        )
        return True
    except Exception:
        return False


def focus_browser_tab(app_name: str, window: int, tab: int) -> bool:
    """Activate a specific tab + bring its window to front."""
    script = (
        f'tell application "{app_name}"\n'
        '  activate\n'
        f'  set active tab index of window {window} to {tab}\n'
        f'  set index of window {window} to 1\n'
        'end tell\n'
    )
    try:
        subprocess.run(["osascript", "-e", script],
                       capture_output=True, timeout=5, check=True)
        return True
    except Exception:
        return False


