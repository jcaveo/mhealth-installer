#!/usr/bin/python3
"""
mhealth-kill — local web UI for killing processes + closing Chrome tabs.

Spawns a tiny HTTP server on a random port, opens it in the default browser.
Sortable table, multi-select, Kill button, plus a Chrome tab list with Close
buttons. Renderer→tab mapping uses JS-heap correlation (best-effort) when
Chrome's "Allow JavaScript from Apple Events" is enabled.

Server self-terminates 60 s after the browser tab is closed (or 10 min idle).
"""
from __future__ import annotations

import http.server
import json
import os
import random
import re
import signal
import socket
import subprocess
import sys
import threading
import time
import datetime
import webbrowser
from typing import Any

# --- Process classification -----------------------------------------------
# level: "critical" = NEVER kill (will break system or session)
#        "risky"    = kill is recoverable but disruptive (respawn/reload)
#        "safe"     = killing only affects that app

PROCESS_INFO: dict[str, tuple[str, str]] = {
    # CRITICAL — kill blocked by UI and server
    "WindowServer":     ("macOS UI compositor — kill = instant logout", "critical"),
